# Local settings
.claude/settings.local.json

# Session kill-switch counters (per-machine run state)
.claude/.killswitch/

# macOS
.DS_Store

# Build artifacts (generated from frontend/ source via `npm run build`)
frontend/build/

# Python bytecode
__pycache__/
*.pyc

# AgentDB (per-machine state)
_meta/agentdb/*.db
_meta/agentdb/*.db-shm
_meta/agentdb/*.db-wal
_meta/agentdb/errors.log

# Logs
_meta/logs/

# Ephemeral state (circuit breaker, compaction markers, test-gate verdict)
_meta/.breakers/
_meta/.compact-marker
_meta/.cache/
_meta/.test-status

# Manifest runtime state (kernel-manifest activate/deactivate)
_meta/.active-manifest.json
_meta/.context-ledger
