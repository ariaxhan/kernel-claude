#!/usr/bin/env bash
# post-commit hook — AUTO-PUSH DISABLED (Aria directive 2026-06-15).
#
# History: per-commit auto-push to a shared `main` across multiple windows caused years of
# rebase/push storms. The fix is not a smarter push — it's NO auto-push. Commits stay LOCAL.
# Pushing is explicit (a human/sweep decision), and work belongs on session branches, never main.
#
# Auto-branching lives in the SessionStart hook (autobranch), not here.
# To push deliberately: `git push` yourself, or run _meta/services/vault-autopush.sh (manual).
exit 0
