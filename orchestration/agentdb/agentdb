#!/bin/bash
# KERNEL AgentDB CLI
# Every agent reads on start, writes on end. No exceptions.
#
# USAGE:
#   agentdb init                    # Initialize per-project DB
#   agentdb read-start              # What to know before working
#   agentdb write-end <json>        # Checkpoint before stopping
#   agentdb learn <type> <insight>  # Record learning
#   agentdb contract <json>         # Create contract
#   agentdb verdict <pass|fail> <evidence>  # QA result
#   agentdb query <sql>             # Raw query
#   agentdb status                  # DB health, counts, last checkpoint time
#   agentdb prune                   # Delete old checkpoints (keep last 10)
#   agentdb export                  # Dump learnings to markdown
#   agentdb recent                  # Show last 5 checkpoints
#   agentdb inject-context <type>   # Build agent-specific context slice
#   agentdb health                  # Check system health

set -euo pipefail

# Dependency check
command -v sqlite3 >/dev/null 2>&1 || { echo "Error: sqlite3 required but not found" >&2; exit 1; }

# Find project root (where .claude/ or _meta/ exists)
find_project_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/_meta" ] || [ -d "$dir/.claude" ]; then
      echo "$dir"
      return
    fi
    dir=$(dirname "$dir")
  done
  echo "$PWD"  # fallback
}

PROJECT_ROOT=$(find_project_root)
DB_DIR="$PROJECT_ROOT/_meta/agentdb"
DB="$DB_DIR/agent.db"
SCHEMA_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"

# === SECURITY: SQL escaping ===
# Escape single quotes for safe SQL insertion
sql_escape() {
  printf '%s' "$1" | sed "s/'/''/g"
}

# JSON-safe escaping (backslashes then double quotes)
json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

# Integer validation for numeric SQL parameters
validate_int() {
  local val="$1"
  local name="${2:-value}"
  [[ "$val" =~ ^[0-9]+$ ]] || { echo "Error: $name must be integer" >&2; exit 1; }
}

# Execute sqlite3 with busy_timeout
db_exec() {
  sqlite3 "$DB" <<EOF
.timeout 5000
$1
EOF
}

# Execute sqlite3 with options and busy_timeout
db_exec_opts() {
  local opts="$1"
  shift
  # shellcheck disable=SC2086
  sqlite3 $opts "$DB" <<EOF
.timeout 5000
$1
EOF
}

# === COMMANDS ===

cmd_init() {
  mkdir -p "$DB_DIR"

  local created_new=false

  # Apply base schema if DB doesn't exist
  if [ ! -f "$DB" ]; then
    created_new=true
    if [ -f "$SCHEMA_DIR/schema.sql" ]; then
      sqlite3 "$DB" "PRAGMA busy_timeout=5000;" ".read $SCHEMA_DIR/schema.sql"
    else
      echo "Error: schema.sql not found at $SCHEMA_DIR/schema.sql" >&2
      echo "Cannot initialize database without schema definition." >&2
      exit 1
    fi
  fi

  # Apply any pending migrations
  if [ -d "$SCHEMA_DIR/migrations" ]; then
    for migration in "$SCHEMA_DIR/migrations"/*.sql; do
      [ -f "$migration" ] || continue
      # Skip rollback files
      [[ "$migration" == *.down.sql ]] && continue
      local name
      name=$(basename "$migration" .sql)
      local applied
      applied=$(db_exec "SELECT 1 FROM _migrations WHERE name='$name' LIMIT 1;" 2>/dev/null || echo "")
      if [ -z "$applied" ]; then
        sqlite3 "$DB" ".timeout 5000" ".read $migration"
        echo "Applied migration: $name"
      fi
    done
  fi

  if [ "$created_new" = true ]; then
    echo "Initialized: $DB"
  else
    echo "DB exists: $DB"
  fi
}

cmd_preflight() {
  # Validate local environment and DB schema integrity
  # Called by session-start hook to catch drift before it causes errors
  local warnings=0
  local repairs=0

  # Check 1: DB exists
  if [ ! -f "$DB" ]; then
    echo "preflight:init — no database found, initializing"
    cmd_init >/dev/null
    repairs=$((repairs + 1))
  fi

  # Check 2: Required tables exist
  local required_tables="learnings context errors _migrations events"
  for table in $required_tables; do
    local exists
    exists=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='$table' LIMIT 1;" 2>/dev/null || echo "")
    if [ -z "$exists" ]; then
      echo "preflight:missing_table — $table not found, applying schema"
      # Re-apply schema (all CREATE TABLE IF NOT EXISTS, safe to re-run)
      if [ -f "$SCHEMA_DIR/schema.sql" ]; then
        sqlite3 "$DB" ".timeout 5000" ".read $SCHEMA_DIR/schema.sql" >/dev/null 2>&1 || true
      fi
      # Re-run migrations only if _migrations table exists (avoid circular dep)
      local has_migrations
      has_migrations=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='_migrations' LIMIT 1;" 2>/dev/null || echo "")
      if [ -n "$has_migrations" ] && [ -d "$SCHEMA_DIR/migrations" ]; then
        for m in "$SCHEMA_DIR/migrations"/*.sql; do
          [ -f "$m" ] || continue
          [[ "$m" == *.down.sql ]] && continue
          local mname
          mname=$(basename "$m" .sql)
          local mapplied
          mapplied=$(db_exec "SELECT 1 FROM _migrations WHERE name='$mname' LIMIT 1;" 2>/dev/null || echo "")
          [ -z "$mapplied" ] && sqlite3 "$DB" ".timeout 5000" ".read $m" 2>/dev/null || true
        done
      fi
      repairs=$((repairs + 1))
      break
    fi
  done

  # Check 3: learnings schema has all expected columns
  local expected_cols="id ts type insight evidence domain hit_count last_hit"
  for col in $expected_cols; do
    local has_col
    has_col=$(db_exec "SELECT 1 FROM pragma_table_info('learnings') WHERE name='$col' LIMIT 1;" 2>/dev/null || echo "")
    if [ -z "$has_col" ]; then
      echo "preflight:missing_column — learnings.$col not found, adding"
      # Determine type for the missing column
      case "$col" in
        hit_count) db_exec "ALTER TABLE learnings ADD COLUMN hit_count INTEGER DEFAULT 0;" 2>/dev/null || true ;;
        last_hit)  db_exec "ALTER TABLE learnings ADD COLUMN last_hit TEXT;" 2>/dev/null || true ;;
        domain)    db_exec "ALTER TABLE learnings ADD COLUMN domain TEXT;" 2>/dev/null || true ;;
        *)         echo "preflight:error — unknown column $col, manual fix required"; warnings=$((warnings + 1)); continue ;;
      esac
      repairs=$((repairs + 1))
    fi
  done

  # Check 4: All migrations applied
  if [ -d "$SCHEMA_DIR/migrations" ]; then
    for migration in "$SCHEMA_DIR/migrations"/*.sql; do
      [ -f "$migration" ] || continue
      [[ "$migration" == *.down.sql ]] && continue
      local name
      name=$(basename "$migration" .sql)
      local applied
      applied=$(db_exec "SELECT 1 FROM _migrations WHERE name='$name' LIMIT 1;" 2>/dev/null || echo "")
      if [ -z "$applied" ]; then
        echo "preflight:pending_migration — $name not applied"
        warnings=$((warnings + 1))
      fi
    done
  fi

  # Check 5: DB is writable (not corrupted or locked)
  local write_test
  write_test=$(db_exec "PRAGMA integrity_check;" 2>/dev/null | head -1 || echo "fail")
  if [ "$write_test" != "ok" ]; then
    echo "preflight:corruption — integrity check failed: $write_test"
    warnings=$((warnings + 1))
  fi

  # Check 6: schema.sql exists (needed for future init/migrations)
  if [ ! -f "$SCHEMA_DIR/schema.sql" ]; then
    echo "preflight:missing_schema — schema.sql not found at $SCHEMA_DIR"
    warnings=$((warnings + 1))
  fi

  # Check 7: DB bloat (>5MB is suspicious for a metadata store)
  local db_bytes
  db_bytes=$(stat -f%z "$DB" 2>/dev/null || stat -c%s "$DB" 2>/dev/null || echo "0")
  if [ "$db_bytes" -gt 5242880 ]; then
    local db_mb=$(( db_bytes / 1048576 ))
    echo "preflight:bloat — agent.db is ${db_mb}MB (consider: agentdb prune all)"
    warnings=$((warnings + 1))
  fi

  # Check 8: Orphan contracts (>48h with no verdict)
  local orphan_count
  orphan_count=$(db_exec "
    SELECT COUNT(*) FROM context
    WHERE type='contract'
      AND ts < datetime('now', '-2 days')
      AND contract_id NOT IN (
        SELECT COALESCE(contract_id, '') FROM context WHERE type='verdict'
      );
  " 2>/dev/null || echo "0")
  if [ "$orphan_count" -gt 0 ]; then
    echo "preflight:orphan_contracts — $orphan_count contract(s) >48h with no verdict (close with: agentdb contract close --stale)"
    warnings=$((warnings + 1))
  fi

  # Check 9: Stale learnings ratio (>50% with 0 hits and >14 days old)
  local total_learnings stale_learnings
  total_learnings=$(db_exec "SELECT COUNT(*) FROM learnings;" 2>/dev/null || echo "0")
  if [ "$total_learnings" -gt 5 ]; then
    stale_learnings=$(db_exec "
      SELECT COUNT(*) FROM learnings
      WHERE hit_count = 0 AND ts < datetime('now', '-14 days');
    " 2>/dev/null || echo "0")
    if [ $(( stale_learnings * 100 / total_learnings )) -gt 50 ]; then
      echo "preflight:stale_learnings — $stale_learnings/$total_learnings learnings never reinforced (consider pruning)"
      warnings=$((warnings + 1))
    fi
  fi

  # Summary
  if [ $warnings -eq 0 ] && [ $repairs -eq 0 ]; then
    echo "preflight:ok"
  else
    echo "preflight:done — $repairs repairs, $warnings warnings"
  fi
  return 0
}

cmd_read_start() {
  # Ensure DB exists
  [ ! -f "$DB" ] && cmd_init >/dev/null

  echo "# AgentDB Context"
  echo ""

  echo "## Recent Failures (AVOID THESE)"
  db_exec "SELECT '- ' || insight FROM learnings WHERE type='failure' ORDER BY ts DESC LIMIT 5;" 2>/dev/null || echo "None"
  echo ""

  echo "## Active Patterns"
  db_exec "SELECT '- ' || insight FROM learnings WHERE type='pattern' ORDER BY hit_count DESC, ts DESC LIMIT 5;" 2>/dev/null || echo "None"
  echo ""

  echo "## Recent Errors"
  db_exec "SELECT '- [' || tool || '] ' || error || COALESCE(' (' || file || ')', '') FROM errors ORDER BY ts DESC LIMIT 5;" 2>/dev/null || echo "None"
  echo ""

  # Error replay detection: warn if recent errors match known failure patterns
  local replay_warnings
  replay_warnings=$(db_exec "
    SELECT DISTINCT '⚠ REPLAY RISK: error \"' || substr(e.error, 1, 60) || '\" matches known failure: ' || l.insight
    FROM errors e
    JOIN learnings l ON l.type = 'failure'
    WHERE e.ts > datetime('now', '-24 hours')
    AND (
      -- Match if error text contains key words from the failure insight
      e.error LIKE '%' || substr(l.insight, 1, 30) || '%'
      OR l.insight LIKE '%' || REPLACE(REPLACE(e.error, CHAR(10), ' '), CHAR(13), ' ') || '%'
      -- Match on tool/domain overlap
      OR (e.tool != 'unknown' AND l.domain IS NOT NULL AND e.tool = l.domain)
    )
    LIMIT 3;
  " 2>/dev/null || echo "")
  if [ -n "$replay_warnings" ]; then
    echo "## ⚠ Error Replay Detection"
    echo "These recent errors match known failure patterns. Review before proceeding:"
    echo "$replay_warnings" | sed 's/^/- /'
    echo ""
  fi

  echo "## Active Contract"
  db_exec "SELECT content FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 1;" 2>/dev/null || echo "None"
  echo ""

  echo "## Last Checkpoint"
  db_exec "SELECT content FROM context WHERE type='checkpoint' ORDER BY ts DESC LIMIT 1;" 2>/dev/null || echo "None"
}

cmd_write_end() {
  local content="${1:-}"
  local agent="${2:-orchestrator}"

  [ -z "$content" ] && { echo "Usage: agentdb write-end <json> [agent]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_content safe_agent
  safe_content=$(sql_escape "$content")
  safe_agent=$(sql_escape "$agent")

  local id="CP-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  db_exec "INSERT INTO context (id, type, agent, content) VALUES ('$id', 'checkpoint', '$safe_agent', '$safe_content');"
  echo "Checkpoint: $id"
}

cmd_learn() {
  local type="${1:-}"
  local insight="${2:-}"
  local evidence="${3:-}"
  local domain="${4:-}"

  [ -z "$type" ] || [ -z "$insight" ] && { echo "Usage: agentdb learn <type> <insight> [evidence] [domain]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  # Escape inputs to prevent SQL injection
  local safe_type safe_insight safe_evidence safe_domain
  safe_type=$(sql_escape "$type")
  safe_insight=$(sql_escape "$insight")
  safe_evidence=$(sql_escape "$evidence")
  safe_domain=$(sql_escape "$domain")

  # Dedup: if similar learning exists, reinforce instead of duplicating
  local safe_substr=$(sql_escape "${insight:0:40}")
  local existing
  existing=$(db_exec "SELECT id FROM learnings WHERE insight LIKE '%${safe_substr}%' AND type='$safe_type' LIMIT 1;" 2>/dev/null || echo "")
  if [ -n "$existing" ]; then
    db_exec "UPDATE learnings SET hit_count = hit_count + 1 WHERE id='$existing';"
    echo "Reinforced: [$type] (existing: $existing)"
    return
  fi

  local id="LRN-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  db_exec "INSERT INTO learnings (id, type, insight, evidence, domain) VALUES ('$id', '$safe_type', '$safe_insight', '$safe_evidence', '$safe_domain');"
  echo "Learned: [$type] $insight"
}

cmd_contract() {
  local subcmd="${1:-}"

  case "$subcmd" in
    close)
      shift
      cmd_contract_close "$@"
      ;;
    list)
      [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
      db_exec_opts "-header -column" "SELECT id, ts, substr(content, 1, 80) || '...' AS summary FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 10;"
      ;;
    *)
      # Original behavior: create contract from JSON
      # Expected format: {"goal":"X","files":["a.sh"],"constraints":{"files":["a.sh","b.md"]},"tier":2}
      # constraints.files: exhaustive list of files the agent is allowed to touch.
      # Surgeons MUST verify git diff --name-only is a subset of constraints.files before commit.
      local content="$subcmd"
      [ -z "$content" ] && { echo "Usage: agentdb contract <json> | close [id|--stale] | list"; exit 1; }
      [ ! -f "$DB" ] && cmd_init >/dev/null

      local safe_content
      safe_content=$(sql_escape "$content")

      local id="CR-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
      db_exec "INSERT INTO context (id, type, agent, content, contract_id) VALUES ('$id', 'contract', 'orchestrator', '$safe_content', '$id');"
      echo "Contract: $id"
      ;;
  esac
}

cmd_contract_close() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  local target="${1:-}"

  if [ "$target" = "--stale" ]; then
    # Close contracts older than 24 hours
    local count
    count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract' AND ts < datetime('now', '-1 day');")
    db_exec "DELETE FROM context WHERE type='contract' AND ts < datetime('now', '-1 day');"
    echo "Closed $count stale contract(s)."
  elif [ -n "$target" ]; then
    # Close specific contract by ID (or partial match)
    local safe_target
    safe_target=$(sql_escape "$target")
    local count
    count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract' AND id LIKE '%${safe_target}%';")
    db_exec "DELETE FROM context WHERE type='contract' AND id LIKE '%${safe_target}%';"
    echo "Closed $count contract(s) matching '$target'."
  else
    # Close all contracts
    local count
    count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")
    db_exec "DELETE FROM context WHERE type='contract';"
    echo "Closed all $count contract(s)."
  fi
}

cmd_verdict() {
  local result="${1:-}"
  local evidence="${2:-}"
  local contract_id="${3:-}"

  [ -z "$result" ] && { echo "Usage: agentdb verdict <pass|fail> <evidence> [contract_id]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_result safe_evidence safe_contract_id
  safe_result=$(sql_escape "$result")
  safe_evidence=$(sql_escape "$evidence")
  safe_contract_id=$(sql_escape "$contract_id")

  local id="VD-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  local content
  if command -v jq >/dev/null 2>&1; then
    content=$(jq -n --arg r "$result" --arg e "$evidence" '{result:$r,evidence:$e}')
  else
    local json_result json_evidence
    json_result=$(json_escape "$result")
    json_evidence=$(json_escape "$evidence")
    content="{\"result\":\"$json_result\",\"evidence\":\"$json_evidence\"}"
  fi
  local safe_content
  safe_content=$(sql_escape "$content")
  db_exec "INSERT INTO context (id, type, agent, content, contract_id) VALUES ('$id', 'verdict', 'adversary', '$safe_content', '$safe_contract_id');"
  echo "Verdict: $result"
}

cmd_error() {
  local tool="${1:-}"
  local error="${2:-}"
  local file="${3:-}"

  [ -z "$tool" ] || [ -z "$error" ] && { echo "Usage: agentdb error <tool> <error> [file]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_tool safe_error safe_file
  safe_tool=$(sql_escape "$tool")
  safe_error=$(sql_escape "$error")
  safe_file=$(sql_escape "$file")

  db_exec "INSERT INTO errors (tool, error, file) VALUES ('$safe_tool', '$safe_error', '$safe_file');"
}

cmd_query() {
  local sql="${1:-}"
  [ -z "$sql" ] && { echo "Usage: agentdb query <sql>"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  db_exec_opts "-header -column" "$sql"
}

cmd_stats() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  echo "Learnings: $(db_exec "SELECT COUNT(*) FROM learnings;")"
  echo "Checkpoints: $(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")"
  echo "Contracts: $(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")"
  echo "Errors: $(db_exec "SELECT COUNT(*) FROM errors;")"
}

cmd_status() {
  [ ! -f "$DB" ] && { echo "No DB at $DB — run: agentdb init"; exit 1; }

  local db_size
  db_size=$(du -sh "$DB" 2>/dev/null | cut -f1)

  local last_cp_ts
  last_cp_ts=$(db_exec "SELECT ts FROM context WHERE type='checkpoint' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)

  echo "# AgentDB Status"
  echo ""
  echo "DB:          $DB"
  echo "Size:        $db_size"
  echo ""
  echo "Counts:"
  echo "  learnings:   $(db_exec "SELECT COUNT(*) FROM learnings;")"
  echo "  checkpoints: $(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")"
  echo "  contracts:   $(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")"
  echo "  verdicts:    $(db_exec "SELECT COUNT(*) FROM context WHERE type='verdict';")"
  echo "  errors:      $(db_exec "SELECT COUNT(*) FROM errors;")"
  echo ""
  echo "Last checkpoint: ${last_cp_ts:-none}"
  echo ""
  echo "Learnings by type:"
  db_exec "SELECT '  ' || type || ': ' || COUNT(*) FROM learnings GROUP BY type ORDER BY type;" 2>/dev/null
}

cmd_prune() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local target="${1:-checkpoints}"
  local keep="${2:-10}"

  # Backward compat: if first arg is a number, treat as "prune checkpoints N"
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    keep="$target"
    target="checkpoints"
  fi

  case "$target" in
    checkpoints)
      validate_int "$keep" "keep"
      local before_count
      before_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")
      db_exec "
        DELETE FROM context
        WHERE type='checkpoint'
          AND id NOT IN (
            SELECT id FROM context
            WHERE type='checkpoint'
            ORDER BY ts DESC
            LIMIT $keep
          );
      "
      local after_count
      after_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")
      echo "Pruned $(( before_count - after_count )) checkpoint(s). Kept $after_count."
      ;;
    errors)
      validate_int "$keep" "keep"
      local before_err
      before_err=$(db_exec "SELECT COUNT(*) FROM errors;")
      db_exec "
        DELETE FROM errors
        WHERE id NOT IN (
          SELECT id FROM errors ORDER BY ts DESC LIMIT $keep
        );
      "
      local after_err
      after_err=$(db_exec "SELECT COUNT(*) FROM errors;")
      echo "Pruned $(( before_err - after_err )) error(s). Kept $after_err."
      ;;
    contracts)
      local before_con
      before_con=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")
      # Keep only the most recent contract, delete rest
      db_exec "
        DELETE FROM context
        WHERE type='contract'
          AND id NOT IN (
            SELECT id FROM context
            WHERE type='contract'
            ORDER BY ts DESC
            LIMIT ${keep}
          );
      "
      local after_con
      after_con=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")
      echo "Pruned $(( before_con - after_con )) contract(s). Kept $after_con."
      ;;
    all)
      cmd_prune checkpoints "$keep"
      cmd_prune errors "$keep"
      cmd_prune contracts 1
      ;;
    *)
      echo "Usage: agentdb prune <checkpoints|errors|contracts|all> [keep_count]" >&2
      exit 1
      ;;
  esac
}

cmd_wtf() {
  # The "what just happened?" command. For confused agents and humans.
  [ ! -f "$DB" ] && { echo "No DB — run: agentdb init"; exit 1; }

  echo "# AgentDB: What's Going On"
  echo ""

  # Last error
  local last_err
  last_err=$(db_exec "SELECT '[' || tool || '] ' || error FROM errors ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Last error: ${last_err:-none}"

  # Last failed verdict
  local last_fail
  last_fail=$(db_exec "SELECT content FROM context WHERE type='verdict' AND content LIKE '%fail%' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Last failed verdict: ${last_fail:-none}"

  # Active contract
  local contract
  contract=$(db_exec "SELECT id || ' — ' || substr(content, 1, 80) FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Active contract: ${contract:-none}"

  # Last checkpoint
  local checkpoint
  checkpoint=$(db_exec "SELECT substr(content, 1, 100) FROM context WHERE type='checkpoint' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Last checkpoint: ${checkpoint:-none}"
  echo ""

  # Recent failures (learnings)
  local failures
  failures=$(db_exec "SELECT COUNT(*) FROM learnings WHERE type='failure';" 2>/dev/null || echo "0")
  if [ "$failures" -gt 0 ]; then
    echo "Recent failure learnings:"
    db_exec "SELECT '  - ' || insight FROM learnings WHERE type='failure' ORDER BY ts DESC LIMIT 3;" 2>/dev/null
    echo ""
  fi

  echo "---"
  echo "Fix: agentdb contract close | agentdb prune errors | agentdb learn failure \"what\" \"evidence\""
}

cmd_timeline() {
  # Unified chronological view across all tables. The git-log of agentdb.
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local n="${1:-20}"
  validate_int "$n" "n"

  db_exec "
    SELECT ts, category, event FROM (
      SELECT ts, 'learning' AS category, type || ': ' || insight AS event FROM learnings
      UNION ALL
      SELECT ts, type AS category, substr(content, 1, 100) AS event FROM context
      UNION ALL
      SELECT ts, 'error' AS category, '[' || tool || '] ' || substr(error, 1, 80) AS event FROM errors
      UNION ALL
      SELECT ts, category, event || CASE WHEN duration_ms IS NOT NULL THEN ' (' || duration_ms || 'ms)' ELSE '' END AS event FROM events
    )
    ORDER BY ts DESC
    LIMIT $n;
  " 2>/dev/null | while IFS='|' read -r ts category event; do
    printf "%-20s  %-12s  %s\n" "$ts" "[$category]" "$event"
  done
}

cmd_guide() {
  cat <<'GUIDE'
# AgentDB Quick Reference

Starting work?      agentdb read-start
Something broke?    agentdb wtf
Learned something?  agentdb learn failure "description" "evidence"
                    agentdb learn pattern "description" "evidence"
Done for now?       agentdb write-end '{"did":"X","next":"Y"}'
What happened?      agentdb timeline 10
Close old work?     agentdb contract close --stale
Clean up?           agentdb prune all
DB healthy?         agentdb preflight
Full reference?     agentdb help
GUIDE
}

cmd_schema() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  local target="${1:-}"

  if [ -n "$target" ]; then
    # Show specific table
    echo "## $target"
    db_exec_opts "-header -column" "SELECT * FROM pragma_table_info('$target');"
  else
    # Show all tables with row counts
    echo "# AgentDB Schema"
    echo ""
    local tables
    tables=$(db_exec "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' ORDER BY name;")
    for t in $tables; do
      local count
      count=$(db_exec "SELECT COUNT(*) FROM \"$t\";" 2>/dev/null || echo "?")
      printf "  %-20s %s rows\n" "$t" "$count"
    done
    echo ""
    echo "Views:"
    db_exec "SELECT '  ' || name FROM sqlite_master WHERE type='view' ORDER BY name;" 2>/dev/null
  fi
}

cmd_export() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local out_file="$DB_DIR/learnings-export-$(date +%Y%m%d%H%M%S).md"

  {
    echo "# AgentDB Learnings Export"
    echo ""
    echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo ""

    echo "## Failures"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || CASE WHEN evidence != '' THEN '- evidence: ' || evidence || char(10) ELSE '' END || '- ts: ' || ts FROM learnings WHERE type='failure' ORDER BY ts DESC;" 2>/dev/null || echo "None"
    echo ""

    echo "## Patterns"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || CASE WHEN evidence != '' THEN '- evidence: ' || evidence || char(10) ELSE '' END || '- hits: ' || hit_count || char(10) || '- ts: ' || ts FROM learnings WHERE type='pattern' ORDER BY hit_count DESC, ts DESC;" 2>/dev/null || echo "None"
    echo ""

    echo "## Gotchas"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || CASE WHEN evidence != '' THEN '- evidence: ' || evidence || char(10) ELSE '' END || '- ts: ' || ts FROM learnings WHERE type='gotcha' ORDER BY ts DESC;" 2>/dev/null || echo "None"
    echo ""

    echo "## Preferences"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || '- ts: ' || ts FROM learnings WHERE type='preference' ORDER BY ts DESC;" 2>/dev/null || echo "None"
  } > "$out_file"

  echo "Exported to: $out_file"
}

cmd_recent() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local n="${1:-5}"
  validate_int "$n" "n"

  echo "# Last $n Checkpoints"
  echo ""
  db_exec_opts "-separator $'\t'" "
    SELECT ts, agent, content
    FROM context
    WHERE type='checkpoint'
    ORDER BY ts DESC
    LIMIT $n;
  " 2>/dev/null | while IFS=$'\t' read -r ts agent content; do
    echo "[$ts] ($agent)"
    echo "  $content"
    echo ""
  done
}

# === GRAPH TRACKING COMMANDS ===

cmd_session_start() {
  local task_type="${1:-}"
  local tier="${2:-1}"

  [ ! -f "$DB" ] && cmd_init >/dev/null

  local id="SES-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  local safe_type
  safe_type=$(sql_escape "$task_type")
  validate_int "$tier" "tier"

  # Check if table exists (migration applied)
  local has_table
  has_table=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='context_sessions' LIMIT 1;" 2>/dev/null || echo "")
  if [ -z "$has_table" ]; then
    echo "Graph tracking not initialized. Run: agentdb init"
    return 1
  fi

  db_exec "INSERT INTO context_sessions (id, task_type, tier) VALUES ('$id', '$safe_type', $tier);"
  echo "$id"
}

cmd_session_end() {
  local session_id="${1:-}"
  local success="${2:-}"
  local outcome="${3:-}"
  local nodes_loaded="${4:-[]}"
  local tokens_used="${5:-0}"

  [ -z "$session_id" ] && { echo "Usage: agentdb session-end <id> <1|0> <outcome_json> [nodes_json] [tokens]"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  validate_int "$success" "success"
  validate_int "$tokens_used" "tokens_used"

  local safe_id safe_outcome safe_nodes
  safe_id=$(sql_escape "$session_id")
  safe_outcome=$(sql_escape "$outcome")
  safe_nodes=$(sql_escape "$nodes_loaded")

  db_exec "
    UPDATE context_sessions SET
      ended_at = strftime('%Y-%m-%dT%H:%M:%fZ','now'),
      success = $success,
      outcome = '$safe_outcome',
      nodes_loaded = '$safe_nodes',
      tokens_used = $tokens_used
    WHERE id = '$safe_id';
  "
  echo "Session closed: $session_id"
}

cmd_track_node() {
  local path="${1:-}"
  local type="${2:-}"
  local tokens="${3:-0}"

  [ -z "$path" ] || [ -z "$type" ] && { echo "Usage: agentdb track-node <path> <type> [tokens]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  validate_int "$tokens" "tokens"

  local safe_path safe_type
  safe_path=$(sql_escape "$path")
  safe_type=$(sql_escape "$type")

  db_exec "
    INSERT INTO nodes (path, type, tokens, last_accessed, access_count)
    VALUES ('$safe_path', '$safe_type', $tokens, strftime('%Y-%m-%dT%H:%M:%fZ','now'), 1)
    ON CONFLICT(path) DO UPDATE SET
      last_accessed = strftime('%Y-%m-%dT%H:%M:%fZ','now'),
      access_count = access_count + 1,
      tokens = COALESCE(excluded.tokens, tokens);
  "
}

cmd_suggest_context() {
  local task_type="${1:-}"
  local max_tokens="${2:-4000}"

  [ -z "$task_type" ] && { echo "Usage: agentdb suggest-context <task_type> [max_tokens]"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  validate_int "$max_tokens" "max_tokens"

  # Find nodes that correlate with success for this task type
  db_exec_opts "-header -column" "
    SELECT DISTINCT
      n.path,
      n.type,
      n.tokens,
      n.avg_success_rate,
      n.access_count
    FROM nodes n
    WHERE n.avg_success_rate > 0.5
      AND n.access_count >= 2
    ORDER BY n.avg_success_rate DESC, n.access_count DESC
    LIMIT 10;
  " 2>/dev/null || echo "No suggestions yet. Need more session data."
}

cmd_emit() {
  local category="${1:?Usage: agentdb emit <category> <event> [duration_ms] [metadata_json] [agent] [session_id]}"
  local event="${2:?Usage: agentdb emit <category> <event>}"
  local duration="${3:-}"
  local metadata="${4:-'{}'}"
  local agent="${5:-}"
  local session_id="${6:-}"

  # Validate category
  case "$category" in
    session|agent|hook|command|error|learning) ;;
    *) echo "Error: category must be one of: session, agent, hook, command, error, learning" >&2; exit 1 ;;
  esac

  local safe_event=$(sql_escape "$event")
  local safe_meta=$(sql_escape "$metadata")
  local safe_agent=$(sql_escape "$agent")
  local safe_session=$(sql_escape "$session_id")

  local duration_sql="NULL"
  if [ -n "$duration" ]; then
    validate_int "$duration" "duration_ms"
    duration_sql="$duration"
  fi

  db_exec "INSERT INTO events (category, event, duration_ms, metadata, agent, session_id)
    VALUES ('$category', '$safe_event', $duration_sql, '$safe_meta', '$safe_agent', '$safe_session');"
  echo "Recorded: [$category] $event"
}

cmd_health() {
  local warnings=0
  local errors=0

  # Schema check
  local migration_count
  migration_count=$(db_exec "SELECT COUNT(*) FROM _migrations;" 2>/dev/null || echo "0")
  if [ "$migration_count" -ge 3 ]; then
    echo "✓ agentdb: OK ($migration_count migrations applied)"
  else
    echo "⚠ agentdb: $migration_count migrations applied (expected 3+)"
    warnings=$((warnings + 1))
  fi

  # Learnings
  local learning_count
  learning_count=$(db_exec "SELECT COUNT(*) FROM learnings;" 2>/dev/null || echo "0")
  local active_learnings
  active_learnings=$(db_exec "SELECT COUNT(*) FROM learnings WHERE hit_count > 0;" 2>/dev/null || echo "0")
  echo "✓ learnings: $learning_count total, $active_learnings reinforced"

  # Events
  local event_count
  event_count=$(db_exec "SELECT COUNT(*) FROM events;" 2>/dev/null || echo "0")
  echo "✓ events: $event_count recorded"

  # Dependencies
  local deps_ok=true
  printf "✓ dependencies:"
  command -v sqlite3 >/dev/null 2>&1 && printf " sqlite3" || { printf " ✗sqlite3"; deps_ok=false; errors=$((errors + 1)); }
  command -v jq >/dev/null 2>&1 && printf " jq" || { printf " ✗jq"; warnings=$((warnings + 1)); }
  command -v gh >/dev/null 2>&1 && printf " gh" || { printf " ✗gh"; warnings=$((warnings + 1)); }
  echo ""

  # gh auth
  if command -v gh >/dev/null 2>&1; then
    if gh auth status >/dev/null 2>&1; then
      echo "✓ gh: authenticated"
    else
      echo "⚠ gh: not authenticated — run 'gh auth login' for GitHub features"
      warnings=$((warnings + 1))
    fi
  fi

  # DB size
  local db_size
  db_size=$(ls -lh "$DB" 2>/dev/null | awk '{print $5}')
  echo "✓ disk: agent.db $db_size"

  # Summary
  if [ "$errors" -gt 0 ]; then
    echo ""; echo "Health: ERRORS ($errors errors, $warnings warnings)"
    return 2
  elif [ "$warnings" -gt 0 ]; then
    echo ""; echo "Health: WARNINGS ($warnings warnings)"
    return 1
  else
    echo ""; echo "Health: OK"
    return 0
  fi
}

cmd_metrics() {
  [ ! -f "$DB" ] && { echo "No DB at $DB"; exit 1; }

  local days="${1:-7}"
  validate_int "$days" "days"

  echo "# KERNEL Metrics (last ${days}d)"
  echo ""

  # === Sessions ===
  local session_count avg_duration_s
  session_count=$(db_exec "SELECT COUNT(*) FROM events WHERE category='session' AND event='session:start' AND ts > datetime('now', '-${days} days');" 2>/dev/null || echo "0")
  avg_duration_s=$(db_exec "SELECT COALESCE(ROUND(AVG(duration_ms) / 1000.0, 0), 0) FROM events WHERE category='session' AND event='session:end' AND duration_ms IS NOT NULL AND ts > datetime('now', '-${days} days');" 2>/dev/null || echo "0")

  echo "## Sessions"
  echo "  Count: $session_count | Avg duration: ${avg_duration_s}s"

  # Tier breakdown from context_sessions if available
  local has_sessions
  has_sessions=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='context_sessions' LIMIT 1;" 2>/dev/null || echo "")
  if [ -n "$has_sessions" ]; then
    echo "  By tier:"
    db_exec "SELECT '    Tier ' || tier || ': ' || COUNT(*) || ' (' || ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM context_sessions WHERE started_at > datetime('now', '-${days} days')), 0) || '%)' FROM context_sessions WHERE started_at > datetime('now', '-${days} days') GROUP BY tier ORDER BY tier;" 2>/dev/null || echo "    No data"
  fi
  echo ""

  # === Agents ===
  echo "## Agents"
  local agent_events
  agent_events=$(db_exec "SELECT COUNT(*) FROM events WHERE category='agent' AND ts > datetime('now', '-${days} days');" 2>/dev/null || echo "0")
  if [ "$agent_events" -gt 0 ] 2>/dev/null; then
    db_exec "SELECT '  ' || COALESCE(agent, json_extract(metadata, '$.agent_type'), 'unknown') || ': ' || COUNT(*) || ' spawned' FROM events WHERE category='agent' AND ts > datetime('now', '-${days} days') GROUP BY COALESCE(agent, json_extract(metadata, '$.agent_type'), 'unknown');" 2>/dev/null || echo "  No data"
  else
    echo "  No agent events recorded"
  fi
  echo ""

  # === Hooks ===
  echo "## Hooks"
  local hook_events
  hook_events=$(db_exec "SELECT COUNT(*) FROM events WHERE category='hook' AND ts > datetime('now', '-${days} days');" 2>/dev/null || echo "0")
  if [ "$hook_events" -gt 0 ] 2>/dev/null; then
    db_exec "SELECT '  ' || event || ': ' || COUNT(*) || ' runs, avg ' || ROUND(AVG(duration_ms), 0) || 'ms' || CASE WHEN SUM(CASE WHEN json_extract(metadata, '$.exit_code') != 0 THEN 1 ELSE 0 END) > 0 THEN ', ' || SUM(CASE WHEN json_extract(metadata, '$.exit_code') != 0 THEN 1 ELSE 0 END) || ' failures' ELSE '' END FROM events WHERE category='hook' AND ts > datetime('now', '-${days} days') GROUP BY event ORDER BY COUNT(*) DESC;" 2>/dev/null || echo "  No data"
  else
    echo "  No hook events recorded"
  fi
  echo ""

  # === Commands ===
  echo "## Commands"
  local cmd_events
  cmd_events=$(db_exec "SELECT COUNT(*) FROM events WHERE category='command' AND ts > datetime('now', '-${days} days');" 2>/dev/null || echo "0")
  if [ "$cmd_events" -gt 0 ] 2>/dev/null; then
    db_exec "SELECT '  ' || event || ': ' || COUNT(*) FROM events WHERE category='command' AND ts > datetime('now', '-${days} days') GROUP BY event ORDER BY COUNT(*) DESC;" 2>/dev/null || echo "  No data"
  else
    echo "  No command events recorded"
  fi
  echo ""

  # === Learnings ===
  echo "## Learnings"
  local total_learnings active_learnings
  total_learnings=$(db_exec "SELECT COUNT(*) FROM learnings;" 2>/dev/null || echo "0")
  active_learnings=$(db_exec "SELECT COUNT(*) FROM learnings WHERE hit_count > 0;" 2>/dev/null || echo "0")
  echo "  Total: $total_learnings | Reinforced: $active_learnings"

  local top_learning
  top_learning=$(db_exec "SELECT '  Top: \"' || SUBSTR(insight, 1, 60) || '\" (' || hit_count || ' hits)' FROM learnings WHERE hit_count > 0 ORDER BY hit_count DESC LIMIT 1;" 2>/dev/null || echo "")
  [ -n "$top_learning" ] && echo "$top_learning"
  echo ""

  # === Adversary Verdicts ===
  echo "## Adversary Verdicts"
  local verdict_count pass_count fail_count
  verdict_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='verdict';" 2>/dev/null || echo "0")
  pass_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='verdict' AND json_extract(content, '$.result')='pass';" 2>/dev/null || echo "0")
  fail_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='verdict' AND json_extract(content, '$.result')='fail';" 2>/dev/null || echo "0")
  echo "  Total: $verdict_count | Pass: $pass_count | Fail: $fail_count"
  if [ "$verdict_count" -lt 5 ] 2>/dev/null; then
    echo "  ⚠ Sample size too small to calibrate"
  fi
  echo ""

  # === Errors ===
  echo "## Errors (last ${days}d)"
  local error_count
  error_count=$(db_exec "SELECT COUNT(*) FROM errors WHERE ts > datetime('now', '-${days} days');" 2>/dev/null || echo "0")
  if [ "$error_count" -gt 0 ] 2>/dev/null; then
    db_exec "SELECT '  ' || tool || ': ' || COUNT(*) FROM errors WHERE ts > datetime('now', '-${days} days') GROUP BY tool ORDER BY COUNT(*) DESC LIMIT 5;" 2>/dev/null || echo "  No data"
  else
    echo "  None"
  fi
}

cmd_inject_context() {
  local agent_type="${1:-surgeon}"
  [ ! -f "$DB" ] && cmd_init >/dev/null

  echo "# Context Injection: $agent_type"
  echo ""

  case "$agent_type" in
    surgeon|implementer)
      echo "## Known Gotchas (AVOID THESE)"
      db_exec "SELECT '- ' || insight FROM learnings WHERE type='failure' ORDER BY hit_count DESC, ts DESC LIMIT 5;" 2>/dev/null || true
      echo ""
      echo "## Proven Patterns (USE THESE)"
      db_exec "SELECT '- ' || insight FROM learnings WHERE type='pattern' ORDER BY hit_count DESC, ts DESC LIMIT 5;" 2>/dev/null || true
      echo ""
      echo "## Active Contract"
      db_exec "SELECT content FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 1;" 2>/dev/null || true
      ;;
    adversary|reviewer)
      echo "## Past Failures (TEST FOR THESE)"
      db_exec "SELECT '- ' || insight || COALESCE(' [' || domain || ']', '') FROM learnings WHERE type='failure' ORDER BY ts DESC LIMIT 10;" 2>/dev/null || true
      echo ""
      echo "## Known Gotchas"
      db_exec "SELECT '- ' || insight FROM learnings WHERE type='gotcha' ORDER BY hit_count DESC LIMIT 5;" 2>/dev/null || true
      echo ""
      echo "## Recent Errors (REGRESSION RISK)"
      db_exec "SELECT '- [' || tool || '] ' || substr(error, 1, 80) FROM errors ORDER BY ts DESC LIMIT 5;" 2>/dev/null || true
      ;;
    researcher|scout)
      echo "## All Learnings by Domain"
      db_exec "SELECT '- [' || COALESCE(domain, 'general') || '] ' || insight FROM learnings ORDER BY domain, ts DESC LIMIT 15;" 2>/dev/null || true
      echo ""
      echo "## Recent Verdicts"
      db_exec "SELECT '- ' || content FROM context WHERE type='verdict' ORDER BY ts DESC LIMIT 3;" 2>/dev/null || true
      ;;
    triage|understudier)
      echo "## Complexity Signals"
      db_exec "SELECT '- ' || insight FROM learnings WHERE type IN ('failure', 'gotcha') ORDER BY ts DESC LIMIT 5;" 2>/dev/null || true
      echo ""
      echo "## Recent Contracts (scope reference)"
      db_exec "SELECT '- ' || content FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 3;" 2>/dev/null || true
      ;;
    *)
      # Default: everything
      cmd_read_start
      ;;
  esac
}

# === DISPATCH ===
case "${1:-help}" in
  init)           cmd_init ;;
  preflight)      cmd_preflight ;;
  read-start)     cmd_read_start ;;
  write-end)      shift; cmd_write_end "$@" ;;
  learn)          shift; cmd_learn "$@" ;;
  contract)       shift; cmd_contract "$@" ;;
  verdict)        shift; cmd_verdict "$@" ;;
  error)          shift; cmd_error "$@" ;;
  query)          shift; cmd_query "$@" ;;
  stats)          cmd_stats ;;
  status)         cmd_status ;;
  prune)          shift; cmd_prune "$@" ;;
  session-start)  shift; cmd_session_start "$@" ;;
  session-end)    shift; cmd_session_end "$@" ;;
  track-node)     shift; cmd_track_node "$@" ;;
  suggest-context) shift; cmd_suggest_context "$@" ;;
  inject-context) shift; cmd_inject_context "$@" ;;
  emit)        shift; cmd_emit "$@" ;;
  health)      cmd_health ;;
  metrics)     shift; cmd_metrics "$@" ;;
  wtf)         cmd_wtf ;;
  timeline)    shift; cmd_timeline "$@" ;;
  guide)       cmd_guide ;;
  schema)      shift; cmd_schema "$@" ;;
  export)      cmd_export ;;
  recent)      shift; cmd_recent "$@" ;;
  *)
    echo "KERNEL AgentDB - Every agent reads on start, writes on end"
    echo ""
    echo "CORE COMMANDS:"
    echo "  init                    Initialize DB + apply migrations"
    echo "  preflight               Validate schema + environment health"
    echo "  read-start              Context for starting work"
    echo "  write-end <json>        Checkpoint before stopping"
    echo "  learn <type> <insight>  Record learning (failure|pattern|gotcha|preference)"
    echo "  contract <json>         Create new contract"
    echo "  contract close [id|--stale]  Close contract(s)"
    echo "  contract list           List recent contracts"
    echo "  verdict <p|f> <evidence>  QA result"
    echo ""
    echo "GRAPH TRACKING (after migration 002):"
    echo "  session-start <type> [tier]  Start tracking a work session"
    echo "  session-end <id> <1|0> <json>  Close session with outcome"
    echo "  track-node <path> <type> [tokens]  Record node access"
    echo "  suggest-context <type>  Suggest context based on success patterns"
    echo ""
    echo "TELEMETRY (after migration 003):"
    echo "  emit <cat> <event> [ms] [json]  Record telemetry event"
    echo "  health                  System health check"
    echo "  metrics [days]              Observability dashboard (default: 7 days)"
    echo ""
    echo "SITUATIONAL AWARENESS:"
    echo "  wtf                     What just happened? (errors, failures, contract)"
    echo "  timeline [N]            Last N events across all tables (default: 20)"
    echo "  guide                   Quick reference cheat sheet"
    echo ""
    echo "KNOWLEDGE INJECTION:"
    echo "  inject-context <type>   Build agent-specific context slice"
    echo ""
    echo "UTILITIES:"
    echo "  status                  DB health, counts"
    echo "  schema [table]          Show tables + row counts, or table columns"
    echo "  prune <target> [N]      Prune: checkpoints|errors|contracts|all"
    echo "  export                  Dump learnings to markdown"
    echo "  recent [N]              Show last N checkpoints"
    echo "  query <sql>             Raw query"
    ;;
esac
