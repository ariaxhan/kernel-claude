      avg_compression=$(db_exec "SELECT ROUND(AVG(compression_ratio) * 100, 0) FROM compaction_events WHERE created_at > datetime('now', '-${days} days');" 2>/dev/null || echo "?")
      echo "  Events: $compact_count | Avg retention: ${avg_retention}% | Avg compression: ${avg_compression}%"
      db_exec "SELECT '  ' || id || ': ' || tokens_before || '→' || tokens_after || ' tokens (' || ROUND(retention_score * 100, 0) || '% retained)' FROM compaction_events WHERE created_at > datetime('now', '-${days} days') ORDER BY created_at DESC LIMIT 3;" 2>/dev/null || true
    else
      echo "  No compaction events recorded"
    fi
  else
    echo "  Table not initialized (run: agentdb init)"
  fi
  echo ""

  # === Errors ===
