cmd_schema() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  local target="${1:-}"

  if [ -n "$target" ]; then
    # Show specific table
    echo "## $target"
    db_exec_opts "-header -column" "SELECT * FROM pragma_table_info('$target');"
  else
    # Show all tables with row counts
    echo "# AgentDB Schema"
    echo ""
    local tables
    tables=$(db_exec "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' ORDER BY name;")
    for t in $tables; do
      local count
      count=$(db_exec "SELECT COUNT(*) FROM \"$t\";" 2>/dev/null || echo "?")
      printf "  %-20s %s rows\n" "$t" "$count"
    done
    echo ""
    echo "Views:"
    db_exec "SELECT '  ' || name FROM sqlite_master WHERE type='view' ORDER BY name;" 2>/dev/null
  fi
}

# Tables to exclude from JSON snapshots: FTS5 virtual + shadow tables (rebuilt on
# import from external content), sqlite internals, and migration bookkeeping (init
# repopulates _migrations). Used by both export-json and import-json.
_is_snapshot_table() {
  case "$1" in
    *_fts|*_fts_*|sqlite_*|_migrations) return 1 ;;
    *) return 0 ;;
  esac
}

# Faithful, deterministic JSON snapshot of agentdb → text file that git can diff/merge.
# Replaces committing the raw binary .db (+ -wal/-shm). Deterministic so identical data
# yields an identical file (sorted keys, rows by rowid, no embedded timestamp).
cmd_export_json() {
  [ ! -f "$DB" ] && { echo "No DB at $DB" >&2; exit 1; }
  command -v jq >/dev/null 2>&1 || { echo "Error: jq required for export-json" >&2; exit 1; }

  local out_file="${1:-$DB_DIR/agent.db.json}"
  local tdir; tdir=$(mktemp -d)
  local acc="$tdir/.acc.json"

  # Migration names only (sorted, no applied_at timestamps → deterministic).
  local migs_json
  migs_json=$(db_exec_opts "-json" "SELECT name FROM _migrations ORDER BY name;" 2>/dev/null \
              | jq -c 'map(.name)' 2>/dev/null) || migs_json=''
  [ -z "$migs_json" ] && migs_json='[]'

  local tables t count=0
  tables=$(db_exec "SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;" 2>/dev/null)

  echo '{}' > "$acc"
  for t in $tables; do
    _is_snapshot_table "$t" || continue
    db_exec_opts "-json" "SELECT * FROM \"$t\" ORDER BY rowid;" > "$tdir/$t.json" 2>/dev/null
    [ -s "$tdir/$t.json" ] || echo '[]' > "$tdir/$t.json"
    jq -S --arg t "$t" --slurpfile rows "$tdir/$t.json" '. + {($t): $rows[0]}' "$acc" \
      > "$acc.tmp" && mv "$acc.tmp" "$acc"
    count=$((count + 1))
  done

  jq -S -n --argjson migs "$migs_json" --slurpfile tbl "$acc" \
     '{format:1, migrations:$migs, tables:$tbl[0]}' > "$out_file"
  rm -rf "$tdir"
  echo "Exported agentdb → $out_file ($count tables)"
}

# Rebuild a fresh DB from a JSON snapshot: init (migrations recreate schema + FTS) →
# load rows via json_each(readfile()) → rebuild the external-content FTS index.
# Refuses to overwrite a live, non-empty DB unless --force is given.
cmd_import_json() {
  command -v jq >/dev/null 2>&1 || { echo "Error: jq required for import-json" >&2; exit 1; }

  local in_file="$DB_DIR/agent.db.json" force=""
  local a
  for a in "$@"; do
    case "$a" in
      --force) force=1 ;;
      *) in_file="$a" ;;
    esac
  done
  [ ! -f "$in_file" ] && { echo "No snapshot at $in_file" >&2; exit 1; }

  if [ -f "$DB" ]; then
    local n; n=$(db_exec "SELECT count(*) FROM learnings;" 2>/dev/null || echo 0)
    if [ "${n:-0}" -gt 0 ] && [ -z "$force" ]; then
      echo "Refusing: $DB already holds $n learnings. Re-run with --force to overwrite." >&2
      exit 1
    fi
  fi

  # Guard passed (DB absent, empty, or --force) → rebuild from a clean slate so a stale
  # or partially-created .db file can't make cmd_init skip schema creation.
  rm -f "$DB" "$DB-wal" "$DB-shm"
  mkdir -p "$DB_DIR"
  _AGENTDB_IMPORTING=1 cmd_init >/dev/null 2>&1 || true

  local tables t cols c collist sellist tmpf
  tables=$(jq -r '.tables | keys[]' "$in_file" 2>/dev/null)
  for t in $tables; do
    _is_snapshot_table "$t" || continue
    cols=$(db_exec "PRAGMA table_info(\"$t\");" 2>/dev/null | awk -F'|' 'NF>1{print $2}')
    [ -z "$cols" ] && { echo "  skip $t (not in schema)" >&2; continue; }
    tmpf=$(mktemp)
    jq -c --arg t "$t" '.tables[$t] // []' "$in_file" > "$tmpf"
    collist=""; sellist=""
    for c in $cols; do
      collist="${collist:+$collist,}\"$c\""
      sellist="${sellist:+$sellist,}json_extract(value,'\$.$c')"
    done
    sqlite3 "$DB" ".timeout 5000" \
      "PRAGMA foreign_keys=OFF; INSERT INTO \"$t\" ($collist) SELECT $sellist FROM json_each(CAST(readfile('$tmpf') AS TEXT));" \
      2>/dev/null || echo "  warn: failed to load $t" >&2
    rm -f "$tmpf"
  done

  # External-content FTS5 (content='learnings') — repopulate the index.
  db_exec "INSERT INTO learnings_fts(learnings_fts) VALUES('rebuild');" 2>/dev/null || true

  echo "Imported $in_file → $DB"
  db_exec "SELECT 'learnings: ' || count(*) FROM learnings;" 2>/dev/null || true
}

