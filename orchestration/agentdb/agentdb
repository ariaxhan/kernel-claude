cmd_session_start() {
  local task_type="${1:-}"
  local tier="${2:-1}"

  [ ! -f "$DB" ] && cmd_init >/dev/null

  local id="SES-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  local safe_type
  safe_type=$(sql_escape "$task_type")
  validate_int "$tier" "tier"

  # Check if table exists (migration applied)
  local has_table
  has_table=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='context_sessions' LIMIT 1;" 2>/dev/null || echo "")
  if [ -z "$has_table" ]; then
    echo "Graph tracking not initialized. Run: agentdb init"
    return 1
  fi

  db_exec "INSERT INTO context_sessions (id, task_type, tier) VALUES ('$id', '$safe_type', $tier);"
  echo "$id"
}

cmd_session_end() {
  local session_id="${1:-}"
  local success="${2:-}"
  local outcome="${3:-}"
  local nodes_loaded="${4:-[]}"
  local tokens_used="${5:-0}"

  [ -z "$session_id" ] && { echo "Usage: agentdb session-end <id> <1|0> <outcome_json> [nodes_json] [tokens]"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  validate_int "$success" "success"
  validate_int "$tokens_used" "tokens_used"

  local safe_id safe_outcome safe_nodes
  safe_id=$(sql_escape "$session_id")
  safe_outcome=$(sql_escape "$outcome")
  safe_nodes=$(sql_escape "$nodes_loaded")

  db_exec "
    UPDATE context_sessions SET
      ended_at = strftime('%Y-%m-%dT%H:%M:%fZ','now'),
      success = $success,
      outcome = '$safe_outcome',
      nodes_loaded = '$safe_nodes',
      tokens_used = $tokens_used
    WHERE id = '$safe_id';
  "
  echo "Session closed: $session_id"
}

cmd_track_node() {
  local path="${1:-}"
  local type="${2:-}"
  local tokens="${3:-0}"

  [ -z "$path" ] || [ -z "$type" ] && { echo "Usage: agentdb track-node <path> <type> [tokens]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  validate_int "$tokens" "tokens"

  local safe_path safe_type
  safe_path=$(sql_escape "$path")
  safe_type=$(sql_escape "$type")

  db_exec "
    INSERT INTO nodes (path, type, tokens, last_accessed, access_count)
    VALUES ('$safe_path', '$safe_type', $tokens, strftime('%Y-%m-%dT%H:%M:%fZ','now'), 1)
    ON CONFLICT(path) DO UPDATE SET
      last_accessed = strftime('%Y-%m-%dT%H:%M:%fZ','now'),
      access_count = access_count + 1,
      tokens = COALESCE(excluded.tokens, tokens);
  "
}

cmd_suggest_context() {
  local task_type="${1:-}"
  local max_tokens="${2:-4000}"

  [ -z "$task_type" ] && { echo "Usage: agentdb suggest-context <task_type> [max_tokens]"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  validate_int "$max_tokens" "max_tokens"

  # Find nodes that correlate with success for this task type
  db_exec_opts "-header -column" "
    SELECT DISTINCT
      n.path,
      n.type,
      n.tokens,
      n.avg_success_rate,
      n.access_count
    FROM nodes n
    WHERE n.avg_success_rate > 0.5
      AND n.access_count >= 2
    ORDER BY n.avg_success_rate DESC, n.access_count DESC
    LIMIT 10;
  " 2>/dev/null || echo "No suggestions yet. Need more session data."
}

cmd_emit() {
  local category="${1:?Usage: agentdb emit <category> <event> [duration_ms] [metadata_json] [agent] [session_id]}"
  local event="${2:?Usage: agentdb emit <category> <event>}"
  local duration="${3:-}"
  local metadata="${4:-'{}'}"
  local agent="${5:-}"
  local session_id="${6:-}"

  # Validate category
  case "$category" in
    session|agent|hook|command|error|learning) ;;
    *) echo "Error: category must be one of: session, agent, hook, command, error, learning" >&2; exit 1 ;;
  esac

  local safe_event=$(sql_escape "$event")
  local safe_meta=$(sql_escape "$metadata")
  local safe_agent=$(sql_escape "$agent")
  local safe_session=$(sql_escape "$session_id")

  local duration_sql="NULL"
  if [ -n "$duration" ]; then
    validate_int "$duration" "duration_ms"
    duration_sql="$duration"
  fi

  db_exec "INSERT INTO events (category, event, duration_ms, metadata, agent, session_id)
    VALUES ('$category', '$safe_event', $duration_sql, '$safe_meta', '$safe_agent', '$safe_session');"
  echo "Recorded: [$category] $event"
}

cmd_health() {
  local warnings=0
  local errors=0

  # Schema check
  local migration_count
  migration_count=$(db_exec "SELECT COUNT(*) FROM _migrations;" 2>/dev/null || echo "0")
  if [ "$migration_count" -ge 3 ]; then
    echo "✓ agentdb: OK ($migration_count migrations applied)"
  else
    echo "⚠ agentdb: $migration_count migrations applied (expected 3+)"
    warnings=$((warnings + 1))
  fi

  # Learnings
  local learning_count
  learning_count=$(db_exec "SELECT COUNT(*) FROM learnings;" 2>/dev/null || echo "0")
  local active_learnings
  active_learnings=$(db_exec "SELECT COUNT(*) FROM learnings WHERE hit_count > 0;" 2>/dev/null || echo "0")
  echo "✓ learnings: $learning_count total, $active_learnings reinforced"

  # Events
  local event_count
  event_count=$(db_exec "SELECT COUNT(*) FROM events;" 2>/dev/null || echo "0")
  echo "✓ events: $event_count recorded"

  # Dependencies
  local deps_ok=true
  printf "✓ dependencies:"
  command -v sqlite3 >/dev/null 2>&1 && printf " sqlite3" || { printf " ✗sqlite3"; deps_ok=false; errors=$((errors + 1)); }
  command -v jq >/dev/null 2>&1 && printf " jq" || { printf " ✗jq"; warnings=$((warnings + 1)); }
  command -v gh >/dev/null 2>&1 && printf " gh" || { printf " ✗gh"; warnings=$((warnings + 1)); }
  echo ""

  # gh auth
  if command -v gh >/dev/null 2>&1; then
    if gh auth status >/dev/null 2>&1; then
      echo "✓ gh: authenticated"
    else
      echo "⚠ gh: not authenticated — run 'gh auth login' for GitHub features"
      warnings=$((warnings + 1))
    fi
  fi

  # DB size
  local db_size
  db_size=$(ls -lh "$DB" 2>/dev/null | awk '{print $5}')
  echo "✓ disk: agent.db $db_size"

  # Summary
  if [ "$errors" -gt 0 ]; then
    echo ""; echo "Health: ERRORS ($errors errors, $warnings warnings)"
    return 2
  elif [ "$warnings" -gt 0 ]; then
    echo ""; echo "Health: WARNINGS ($warnings warnings)"
    return 1
  else
    echo ""; echo "Health: OK"
    return 0
  fi
}

cmd_metrics() {
