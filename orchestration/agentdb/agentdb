cmd_prune() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local target="${1:-checkpoints}"
  local keep="${2:-10}"

  # Backward compat: if first arg is a number, treat as "prune checkpoints N"
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    keep="$target"
    target="checkpoints"
  fi

  case "$target" in
    checkpoints)
      validate_int "$keep" "keep"
      local before_count
      before_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")
      db_exec "
        DELETE FROM context
        WHERE type='checkpoint'
          AND id NOT IN (
            SELECT id FROM context
            WHERE type='checkpoint'
            ORDER BY ts DESC
            LIMIT $keep
          );
      "
      local after_count
      after_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")
      echo "Pruned $(( before_count - after_count )) checkpoint(s). Kept $after_count."
      ;;
    errors)
      validate_int "$keep" "keep"
      local before_err
      before_err=$(db_exec "SELECT COUNT(*) FROM errors;")
      db_exec "
        DELETE FROM errors
        WHERE id NOT IN (
          SELECT id FROM errors ORDER BY ts DESC LIMIT $keep
        );
      "
      local after_err
      after_err=$(db_exec "SELECT COUNT(*) FROM errors;")
      echo "Pruned $(( before_err - after_err )) error(s). Kept $after_err."
      ;;
    contracts)
      local before_con
      before_con=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")
      # Keep only the most recent contract, delete rest
      db_exec "
        DELETE FROM context
        WHERE type='contract'
          AND id NOT IN (
            SELECT id FROM context
            WHERE type='contract'
            ORDER BY ts DESC
            LIMIT ${keep}
          );
      "
      local after_con
      after_con=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")
      echo "Pruned $(( before_con - after_con )) contract(s). Kept $after_con."
      ;;
    learnings)
      # H081: Prune stale learnings. Safe targets: hit_count=0, >14 days old, pattern/preference type.
      # Failures and gotchas are never auto-pruned (safety-critical).
      local before_lrn
      before_lrn=$(db_exec "SELECT COUNT(*) FROM learnings;")
      local pruned_lrn
      pruned_lrn=$(db_exec "SELECT COUNT(*) FROM learnings WHERE hit_count = 0 AND julianday('now') - julianday(ts) > 14 AND type IN ('pattern', 'preference');")
      db_exec "
        DELETE FROM learnings
        WHERE hit_count = 0
          AND julianday('now') - julianday(ts) > 14
          AND type IN ('pattern', 'preference');
      "
      local after_lrn
      after_lrn=$(db_exec "SELECT COUNT(*) FROM learnings;")
      echo "Pruned $pruned_lrn stale learning(s) (hit=0, >14d, pattern/preference). $after_lrn remain."
      ;;
    all)
      cmd_prune checkpoints "$keep"
      cmd_prune errors "$keep"
      cmd_prune contracts 1
      cmd_prune learnings
      ;;
    *)
      echo "Usage: agentdb prune <checkpoints|errors|contracts|learnings|all> [keep_count]" >&2
      exit 1
      ;;
  esac
}

cmd_wtf() {
  # The "what just happened?" command. For confused agents and humans.
  [ ! -f "$DB" ] && { echo "No DB — run: agentdb init"; exit 1; }

  echo "# AgentDB: What's Going On"
  echo ""

  # Last error
  local last_err
  last_err=$(db_exec "SELECT '[' || tool || '] ' || error FROM errors ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Last error: ${last_err:-none}"

  # Last failed verdict
  local last_fail
  last_fail=$(db_exec "SELECT content FROM context WHERE type='verdict' AND content LIKE '%fail%' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Last failed verdict: ${last_fail:-none}"

  # Active contract
  local contract
  contract=$(db_exec "SELECT id || ' — ' || substr(content, 1, 80) FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Active contract: ${contract:-none}"

  # Last checkpoint
  local checkpoint
  checkpoint=$(db_exec "SELECT substr(content, 1, 100) FROM context WHERE type='checkpoint' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)
  echo "Last checkpoint: ${checkpoint:-none}"
  echo ""

  # Recent failures (learnings)
  local failures
  failures=$(db_exec "SELECT COUNT(*) FROM learnings WHERE type='failure';" 2>/dev/null || echo "0")
  if [ "$failures" -gt 0 ]; then
    echo "Recent failure learnings:"
    db_exec "SELECT '  - ' || insight FROM learnings WHERE type='failure' ORDER BY ts DESC LIMIT 3;" 2>/dev/null
    echo ""
  fi

  echo "---"
  echo "Fix: agentdb contract close | agentdb prune errors | agentdb learn failure \"what\" \"evidence\""
}

cmd_timeline() {
  # Unified chronological view across all tables. The git-log of agentdb.
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local n="${1:-20}"
  validate_int "$n" "n"

  db_exec "
    SELECT ts, category, event FROM (
      SELECT ts, 'learning' AS category, type || ': ' || insight AS event FROM learnings
      UNION ALL
      SELECT ts, type AS category, substr(content, 1, 100) AS event FROM context
      UNION ALL
      SELECT ts, 'error' AS category, '[' || tool || '] ' || substr(error, 1, 80) AS event FROM errors
      UNION ALL
      SELECT ts, category, event || CASE WHEN duration_ms IS NOT NULL THEN ' (' || duration_ms || 'ms)' ELSE '' END AS event FROM events
    )
    ORDER BY ts DESC
    LIMIT $n;
  " 2>/dev/null | while IFS='|' read -r ts category event; do
    printf "%-20s  %-12s  %s\n" "$ts" "[$category]" "$event"
  done
}

