#!/bin/bash
# KERNEL AgentDB CLI
# Every agent reads on start, writes on end. No exceptions.
#
# USAGE:
#   agentdb init                    # Initialize per-project DB
#   agentdb read-start              # What to know before working
#   agentdb write-end <json>        # Checkpoint before stopping
#   agentdb learn <type> <insight>  # Record learning
#   agentdb contract <json>         # Create contract
#   agentdb verdict <pass|fail> <evidence>  # QA result
#   agentdb query <sql>             # Raw query
#   agentdb status                  # DB health, counts, last checkpoint time
#   agentdb prune                   # Delete old checkpoints (keep last 10)
#   agentdb export                  # Dump learnings to markdown
#   agentdb recent                  # Show last 5 checkpoints
#   agentdb health                  # Check system health

set -euo pipefail

# Dependency check
command -v sqlite3 >/dev/null 2>&1 || { echo "Error: sqlite3 required but not found" >&2; exit 1; }

# Find project root (where .claude/ or _meta/ exists)
find_project_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/_meta" ] || [ -d "$dir/.claude" ]; then
      echo "$dir"
      return
    fi
    dir=$(dirname "$dir")
  done
  echo "$PWD"  # fallback
}

PROJECT_ROOT=$(find_project_root)
DB_DIR="$PROJECT_ROOT/_meta/agentdb"
DB="$DB_DIR/agent.db"
SCHEMA_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"

# === SECURITY: SQL escaping ===
# Escape single quotes for safe SQL insertion
sql_escape() {
  printf '%s' "$1" | sed "s/'/''/g"
}

# JSON-safe escaping (backslashes then double quotes)
json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

# Integer validation for numeric SQL parameters
validate_int() {
  local val="$1"
  local name="${2:-value}"
  [[ "$val" =~ ^[0-9]+$ ]] || { echo "Error: $name must be integer" >&2; exit 1; }
}

# Execute sqlite3 with busy_timeout
db_exec() {
  sqlite3 "$DB" <<EOF
.timeout 5000
$1
EOF
}

# Execute sqlite3 with options and busy_timeout
db_exec_opts() {
  local opts="$1"
  shift
  # shellcheck disable=SC2086
  sqlite3 $opts "$DB" <<EOF
.timeout 5000
$1
EOF
}

# === COMMANDS ===

cmd_init() {
  mkdir -p "$DB_DIR"

  local created_new=false

  # Apply base schema if DB doesn't exist
  if [ ! -f "$DB" ]; then
    created_new=true
    if [ -f "$SCHEMA_DIR/schema.sql" ]; then
      sqlite3 "$DB" "PRAGMA busy_timeout=5000;" ".read $SCHEMA_DIR/schema.sql"
    else
      # Inline schema — must match schema.sql exactly
      sqlite3 "$DB" "
        PRAGMA journal_mode=WAL;
        PRAGMA foreign_keys=ON;
        PRAGMA busy_timeout=5000;
        CREATE TABLE IF NOT EXISTS learnings (
          id TEXT PRIMARY KEY,
          ts TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ','now')),
          type TEXT NOT NULL CHECK(type IN ('failure','pattern','gotcha','preference')),
          insight TEXT NOT NULL,
          evidence TEXT,
          domain TEXT,
          hit_count INTEGER DEFAULT 0,
          last_hit TEXT
        );
        CREATE TABLE IF NOT EXISTS context (
          id TEXT PRIMARY KEY,
          ts TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ','now')),
          type TEXT NOT NULL CHECK(type IN ('contract','checkpoint','handoff','verdict')),
          contract_id TEXT,
          agent TEXT,
          content TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS errors (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          ts TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ','now')),
          tool TEXT NOT NULL,
          error TEXT NOT NULL,
          file TEXT,
          context TEXT
        );
        CREATE TABLE IF NOT EXISTS _migrations (
          name TEXT PRIMARY KEY,
          applied_at TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ','now'))
        );
        INSERT OR IGNORE INTO _migrations (name) VALUES ('001_init');
        CREATE TABLE IF NOT EXISTS events (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          ts TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ','now')),
          category TEXT NOT NULL CHECK(category IN ('session','agent','hook','command','error','learning')),
          event TEXT NOT NULL,
          duration_ms INTEGER,
          metadata TEXT,
          agent TEXT,
          session_id TEXT
        );
        CREATE INDEX IF NOT EXISTS idx_events_category ON events(category);
        CREATE INDEX IF NOT EXISTS idx_events_ts ON events(ts);
        CREATE INDEX IF NOT EXISTS idx_events_session ON events(session_id);
        CREATE INDEX IF NOT EXISTS idx_learnings_type ON learnings(type);
        CREATE INDEX IF NOT EXISTS idx_learnings_domain ON learnings(domain);
        CREATE INDEX IF NOT EXISTS idx_context_type ON context(type);
        CREATE INDEX IF NOT EXISTS idx_context_contract ON context(contract_id);
        CREATE INDEX IF NOT EXISTS idx_context_ts ON context(ts);
      "
    fi
  fi

  # Apply any pending migrations
  if [ -d "$SCHEMA_DIR/migrations" ]; then
    for migration in "$SCHEMA_DIR/migrations"/*.sql; do
      [ -f "$migration" ] || continue
      local name
      name=$(basename "$migration" .sql)
      local applied
      applied=$(db_exec "SELECT 1 FROM _migrations WHERE name='$name' LIMIT 1;" 2>/dev/null || echo "")
      if [ -z "$applied" ]; then
        sqlite3 "$DB" ".timeout 5000" ".read $migration"
        echo "Applied migration: $name"
      fi
    done
  fi

  if [ "$created_new" = true ]; then
    echo "Initialized: $DB"
  else
    echo "DB exists: $DB"
  fi
}

cmd_read_start() {
  # Ensure DB exists
  [ ! -f "$DB" ] && cmd_init >/dev/null

  echo "# AgentDB Context"
  echo ""

  echo "## Recent Failures (AVOID THESE)"
  db_exec "SELECT '- ' || insight FROM learnings WHERE type='failure' ORDER BY ts DESC LIMIT 5;" 2>/dev/null || echo "None"
  echo ""

  echo "## Active Patterns"
  db_exec "SELECT '- ' || insight FROM learnings WHERE type='pattern' ORDER BY hit_count DESC, ts DESC LIMIT 5;" 2>/dev/null || echo "None"
  echo ""

  echo "## Recent Errors"
  db_exec "SELECT '- [' || tool || '] ' || error || COALESCE(' (' || file || ')', '') FROM errors ORDER BY ts DESC LIMIT 5;" 2>/dev/null || echo "None"
  echo ""

  echo "## Active Contract"
  db_exec "SELECT content FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 1;" 2>/dev/null || echo "None"
  echo ""

  echo "## Last Checkpoint"
  db_exec "SELECT content FROM context WHERE type='checkpoint' ORDER BY ts DESC LIMIT 1;" 2>/dev/null || echo "None"
}

cmd_write_end() {
  local content="${1:-}"
  local agent="${2:-orchestrator}"

  [ -z "$content" ] && { echo "Usage: agentdb write-end <json> [agent]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_content safe_agent
  safe_content=$(sql_escape "$content")
  safe_agent=$(sql_escape "$agent")

  local id="CP-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  db_exec "INSERT INTO context (id, type, agent, content) VALUES ('$id', 'checkpoint', '$safe_agent', '$safe_content');"
  echo "Checkpoint: $id"
}

cmd_learn() {
  local type="${1:-}"
  local insight="${2:-}"
  local evidence="${3:-}"
  local domain="${4:-}"

  [ -z "$type" ] || [ -z "$insight" ] && { echo "Usage: agentdb learn <type> <insight> [evidence] [domain]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  # Escape inputs to prevent SQL injection
  local safe_type safe_insight safe_evidence safe_domain
  safe_type=$(sql_escape "$type")
  safe_insight=$(sql_escape "$insight")
  safe_evidence=$(sql_escape "$evidence")
  safe_domain=$(sql_escape "$domain")

  # Dedup: if similar learning exists, reinforce instead of duplicating
  local safe_substr=$(sql_escape "${insight:0:40}")
  local existing
  existing=$(db_exec "SELECT id FROM learnings WHERE insight LIKE '%${safe_substr}%' AND type='$safe_type' LIMIT 1;" 2>/dev/null || echo "")
  if [ -n "$existing" ]; then
    db_exec "UPDATE learnings SET hit_count = hit_count + 1, last_hit = strftime('%Y-%m-%dT%H:%M:%fZ','now') WHERE id='$existing';"
    echo "Reinforced: [$type] (existing: $existing)"
    return
  fi

  local id="LRN-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  db_exec "INSERT INTO learnings (id, type, insight, evidence, domain) VALUES ('$id', '$safe_type', '$safe_insight', '$safe_evidence', '$safe_domain');"
  echo "Learned: [$type] $insight"
}

cmd_contract() {
  local content="${1:-}"

  [ -z "$content" ] && { echo "Usage: agentdb contract <json>"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_content
  safe_content=$(sql_escape "$content")

  local id="CR-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  db_exec "INSERT INTO context (id, type, agent, content, contract_id) VALUES ('$id', 'contract', 'orchestrator', '$safe_content', '$id');"
  echo "Contract: $id"
}

cmd_verdict() {
  local result="${1:-}"
  local evidence="${2:-}"
  local contract_id="${3:-}"

  [ -z "$result" ] && { echo "Usage: agentdb verdict <pass|fail> <evidence> [contract_id]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_result safe_evidence safe_contract_id
  safe_result=$(sql_escape "$result")
  safe_evidence=$(sql_escape "$evidence")
  safe_contract_id=$(sql_escape "$contract_id")

  local id="VD-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  local content
  if command -v jq >/dev/null 2>&1; then
    content=$(jq -n --arg r "$result" --arg e "$evidence" '{result:$r,evidence:$e}')
  else
    local json_result json_evidence
    json_result=$(json_escape "$result")
    json_evidence=$(json_escape "$evidence")
    content="{\"result\":\"$json_result\",\"evidence\":\"$json_evidence\"}"
  fi
  local safe_content
  safe_content=$(sql_escape "$content")
  db_exec "INSERT INTO context (id, type, agent, content, contract_id) VALUES ('$id', 'verdict', 'adversary', '$safe_content', '$safe_contract_id');"
  echo "Verdict: $result"
}

cmd_error() {
  local tool="${1:-}"
  local error="${2:-}"
  local file="${3:-}"

  [ -z "$tool" ] || [ -z "$error" ] && { echo "Usage: agentdb error <tool> <error> [file]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_tool safe_error safe_file
  safe_tool=$(sql_escape "$tool")
  safe_error=$(sql_escape "$error")
  safe_file=$(sql_escape "$file")

  db_exec "INSERT INTO errors (tool, error, file) VALUES ('$safe_tool', '$safe_error', '$safe_file');"
}

cmd_query() {
  local sql="${1:-}"
  [ -z "$sql" ] && { echo "Usage: agentdb query <sql>"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  db_exec_opts "-header -column" "$sql"
}

cmd_stats() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  echo "Learnings: $(db_exec "SELECT COUNT(*) FROM learnings;")"
  echo "Checkpoints: $(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")"
  echo "Contracts: $(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")"
  echo "Errors: $(db_exec "SELECT COUNT(*) FROM errors;")"
}

cmd_status() {
  [ ! -f "$DB" ] && { echo "No DB at $DB — run: agentdb init"; exit 1; }

  local db_size
  db_size=$(du -sh "$DB" 2>/dev/null | cut -f1)

  local last_cp_ts
  last_cp_ts=$(db_exec "SELECT ts FROM context WHERE type='checkpoint' ORDER BY ts DESC LIMIT 1;" 2>/dev/null)

  echo "# AgentDB Status"
  echo ""
  echo "DB:          $DB"
  echo "Size:        $db_size"
  echo ""
  echo "Counts:"
  echo "  learnings:   $(db_exec "SELECT COUNT(*) FROM learnings;")"
  echo "  checkpoints: $(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")"
  echo "  contracts:   $(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")"
  echo "  verdicts:    $(db_exec "SELECT COUNT(*) FROM context WHERE type='verdict';")"
  echo "  errors:      $(db_exec "SELECT COUNT(*) FROM errors;")"
  echo ""
  echo "Last checkpoint: ${last_cp_ts:-none}"
  echo ""
  echo "Learnings by type:"
  db_exec "SELECT '  ' || type || ': ' || COUNT(*) FROM learnings GROUP BY type ORDER BY type;" 2>/dev/null
}

cmd_prune() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local keep="${1:-10}"
  validate_int "$keep" "keep"

  local before_count
  before_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")

  db_exec "
    DELETE FROM context
    WHERE type='checkpoint'
      AND id NOT IN (
        SELECT id FROM context
        WHERE type='checkpoint'
        ORDER BY ts DESC
        LIMIT $keep
      );
  "

  local after_count
  after_count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='checkpoint';")
  local removed=$(( before_count - after_count ))

  echo "Pruned $removed checkpoint(s). Kept $after_count (of last $keep)."
}

cmd_export() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local out_file="$DB_DIR/learnings-export-$(date +%Y%m%d%H%M%S).md"

  {
    echo "# AgentDB Learnings Export"
    echo ""
    echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo ""

    echo "## Failures"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || CASE WHEN evidence != '' THEN '- evidence: ' || evidence || char(10) ELSE '' END || '- ts: ' || ts FROM learnings WHERE type='failure' ORDER BY ts DESC;" 2>/dev/null || echo "None"
    echo ""

    echo "## Patterns"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || CASE WHEN evidence != '' THEN '- evidence: ' || evidence || char(10) ELSE '' END || '- hits: ' || hit_count || char(10) || '- ts: ' || ts FROM learnings WHERE type='pattern' ORDER BY hit_count DESC, ts DESC;" 2>/dev/null || echo "None"
    echo ""

    echo "## Gotchas"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || CASE WHEN evidence != '' THEN '- evidence: ' || evidence || char(10) ELSE '' END || '- ts: ' || ts FROM learnings WHERE type='gotcha' ORDER BY ts DESC;" 2>/dev/null || echo "None"
    echo ""

    echo "## Preferences"
    echo ""
    db_exec "SELECT '### ' || id || char(10) || '- insight: ' || insight || char(10) || '- ts: ' || ts FROM learnings WHERE type='preference' ORDER BY ts DESC;" 2>/dev/null || echo "None"
  } > "$out_file"

  echo "Exported to: $out_file"
}

cmd_recent() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local n="${1:-5}"
  validate_int "$n" "n"

  echo "# Last $n Checkpoints"
  echo ""
  db_exec_opts "-separator $'\t'" "
    SELECT ts, agent, content
    FROM context
    WHERE type='checkpoint'
    ORDER BY ts DESC
    LIMIT $n;
  " 2>/dev/null | while IFS=$'\t' read -r ts agent content; do
    echo "[$ts] ($agent)"
    echo "  $content"
    echo ""
  done
}

# === GRAPH TRACKING COMMANDS ===

cmd_session_start() {
  local task_type="${1:-}"
  local tier="${2:-1}"

  [ ! -f "$DB" ] && cmd_init >/dev/null

  local id="SES-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  local safe_type
  safe_type=$(sql_escape "$task_type")
  validate_int "$tier" "tier"

  # Check if table exists (migration applied)
  local has_table
  has_table=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='context_sessions' LIMIT 1;" 2>/dev/null || echo "")
  if [ -z "$has_table" ]; then
    echo "Graph tracking not initialized. Run: agentdb init"
    return 1
  fi

  db_exec "INSERT INTO context_sessions (id, task_type, tier) VALUES ('$id', '$safe_type', $tier);"
  echo "$id"
}

cmd_session_end() {
  local session_id="${1:-}"
  local success="${2:-}"
  local outcome="${3:-}"
  local nodes_loaded="${4:-[]}"
  local tokens_used="${5:-0}"

  [ -z "$session_id" ] && { echo "Usage: agentdb session-end <id> <1|0> <outcome_json> [nodes_json] [tokens]"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  validate_int "$success" "success"
  validate_int "$tokens_used" "tokens_used"

  local safe_id safe_outcome safe_nodes
  safe_id=$(sql_escape "$session_id")
  safe_outcome=$(sql_escape "$outcome")
  safe_nodes=$(sql_escape "$nodes_loaded")

  db_exec "
    UPDATE context_sessions SET
      ended_at = strftime('%Y-%m-%dT%H:%M:%fZ','now'),
      success = $success,
      outcome = '$safe_outcome',
      nodes_loaded = '$safe_nodes',
      tokens_used = $tokens_used
    WHERE id = '$safe_id';
  "
  echo "Session closed: $session_id"
}

cmd_track_node() {
  local path="${1:-}"
  local type="${2:-}"
  local tokens="${3:-0}"

  [ -z "$path" ] || [ -z "$type" ] && { echo "Usage: agentdb track-node <path> <type> [tokens]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  validate_int "$tokens" "tokens"

  local safe_path safe_type
  safe_path=$(sql_escape "$path")
  safe_type=$(sql_escape "$type")

  db_exec "
    INSERT INTO nodes (path, type, tokens, last_accessed, access_count)
    VALUES ('$safe_path', '$safe_type', $tokens, strftime('%Y-%m-%dT%H:%M:%fZ','now'), 1)
    ON CONFLICT(path) DO UPDATE SET
      last_accessed = strftime('%Y-%m-%dT%H:%M:%fZ','now'),
      access_count = access_count + 1,
      tokens = COALESCE(excluded.tokens, tokens);
  "
}

cmd_suggest_context() {
  local task_type="${1:-}"
  local max_tokens="${2:-4000}"

  [ -z "$task_type" ] && { echo "Usage: agentdb suggest-context <task_type> [max_tokens]"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  validate_int "$max_tokens" "max_tokens"

  # Find nodes that correlate with success for this task type
  db_exec_opts "-header -column" "
    SELECT DISTINCT
      n.path,
      n.type,
      n.tokens,
      n.avg_success_rate,
      n.access_count
    FROM nodes n
    WHERE n.avg_success_rate > 0.5
      AND n.access_count >= 2
    ORDER BY n.avg_success_rate DESC, n.access_count DESC
    LIMIT 10;
  " 2>/dev/null || echo "No suggestions yet. Need more session data."
}

cmd_emit() {
  local category="${1:?Usage: agentdb emit <category> <event> [duration_ms] [metadata_json] [agent] [session_id]}"
  local event="${2:?Usage: agentdb emit <category> <event>}"
  local duration="${3:-}"
  local metadata="${4:-'{}'}"
  local agent="${5:-}"
  local session_id="${6:-}"

  # Validate category
  case "$category" in
    session|agent|hook|command|error|learning) ;;
    *) echo "Error: category must be one of: session, agent, hook, command, error, learning" >&2; exit 1 ;;
  esac

  local safe_event=$(sql_escape "$event")
  local safe_meta=$(sql_escape "$metadata")
  local safe_agent=$(sql_escape "$agent")
  local safe_session=$(sql_escape "$session_id")

  local duration_sql="NULL"
  if [ -n "$duration" ]; then
    validate_int "$duration" "duration_ms"
    duration_sql="$duration"
  fi

  db_exec "INSERT INTO events (category, event, duration_ms, metadata, agent, session_id)
    VALUES ('$category', '$safe_event', $duration_sql, '$safe_meta', '$safe_agent', '$safe_session');"
  echo "Recorded: [$category] $event"
}

cmd_health() {
  local warnings=0
  local errors=0

  # Schema check
  local migration_count
  migration_count=$(db_exec "SELECT COUNT(*) FROM _migrations;" 2>/dev/null || echo "0")
  if [ "$migration_count" -ge 3 ]; then
    echo "✓ agentdb: OK ($migration_count migrations applied)"
  else
    echo "⚠ agentdb: $migration_count migrations applied (expected 3+)"
    warnings=$((warnings + 1))
  fi

  # Learnings
  local learning_count
  learning_count=$(db_exec "SELECT COUNT(*) FROM learnings;" 2>/dev/null || echo "0")
  local active_learnings
  active_learnings=$(db_exec "SELECT COUNT(*) FROM learnings WHERE hit_count > 0;" 2>/dev/null || echo "0")
  echo "✓ learnings: $learning_count total, $active_learnings reinforced"

  # Events
  local event_count
  event_count=$(db_exec "SELECT COUNT(*) FROM events;" 2>/dev/null || echo "0")
  echo "✓ events: $event_count recorded"

  # Dependencies
  local deps_ok=true
  printf "✓ dependencies:"
  command -v sqlite3 >/dev/null 2>&1 && printf " sqlite3" || { printf " ✗sqlite3"; deps_ok=false; errors=$((errors + 1)); }
  command -v jq >/dev/null 2>&1 && printf " jq" || { printf " ✗jq"; warnings=$((warnings + 1)); }
  command -v gh >/dev/null 2>&1 && printf " gh" || { printf " ✗gh"; warnings=$((warnings + 1)); }
  echo ""

  # gh auth
  if command -v gh >/dev/null 2>&1; then
    if gh auth status >/dev/null 2>&1; then
      echo "✓ gh: authenticated"
    else
      echo "⚠ gh: not authenticated — run 'gh auth login' for GitHub features"
      warnings=$((warnings + 1))
    fi
  fi

  # DB size
  local db_size
  db_size=$(ls -lh "$DB" 2>/dev/null | awk '{print $5}')
  echo "✓ disk: agent.db $db_size"

  # Summary
  if [ "$errors" -gt 0 ]; then
    echo ""; echo "Health: ERRORS ($errors errors, $warnings warnings)"
    return 2
  elif [ "$warnings" -gt 0 ]; then
    echo ""; echo "Health: WARNINGS ($warnings warnings)"
    return 1
  else
    echo ""; echo "Health: OK"
    return 0
  fi
}

# === DISPATCH ===
case "${1:-help}" in
  init)           cmd_init ;;
  read-start)     cmd_read_start ;;
  write-end)      shift; cmd_write_end "$@" ;;
  learn)          shift; cmd_learn "$@" ;;
  contract)       shift; cmd_contract "$@" ;;
  verdict)        shift; cmd_verdict "$@" ;;
  error)          shift; cmd_error "$@" ;;
  query)          shift; cmd_query "$@" ;;
  stats)          cmd_stats ;;
  status)         cmd_status ;;
  prune)          shift; cmd_prune "$@" ;;
  session-start)  shift; cmd_session_start "$@" ;;
  session-end)    shift; cmd_session_end "$@" ;;
  track-node)     shift; cmd_track_node "$@" ;;
  suggest-context) shift; cmd_suggest_context "$@" ;;
  emit)        shift; cmd_emit "$@" ;;
  health)      cmd_health ;;
  export)      cmd_export ;;
  recent)      shift; cmd_recent "$@" ;;
  *)
    echo "KERNEL AgentDB - Every agent reads on start, writes on end"
    echo ""
    echo "CORE COMMANDS:"
    echo "  init                    Initialize DB + apply migrations"
    echo "  read-start              Context for starting work"
    echo "  write-end <json>        Checkpoint before stopping"
    echo "  learn <type> <insight>  Record learning (failure|pattern|gotcha|preference)"
    echo "  contract <json>         Create new contract"
    echo "  verdict <p|f> <evidence>  QA result"
    echo ""
    echo "GRAPH TRACKING (after migration 002):"
    echo "  session-start <type> [tier]  Start tracking a work session"
    echo "  session-end <id> <1|0> <json>  Close session with outcome"
    echo "  track-node <path> <type> [tokens]  Record node access"
    echo "  suggest-context <type>  Suggest context based on success patterns"
    echo ""
    echo "TELEMETRY (after migration 003):"
    echo "  emit <cat> <event> [ms] [json]  Record telemetry event"
    echo "  health                  System health check"
    echo ""
    echo "UTILITIES:"
    echo "  status                  DB health, counts"
    echo "  prune [N]               Keep last N checkpoints"
    echo "  export                  Dump learnings to markdown"
    echo "  recent [N]              Show last N checkpoints"
    echo "  stats                   Show counts"
    echo "  query <sql>             Raw query"
    ;;
esac
