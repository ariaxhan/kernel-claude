cmd_decay() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  # Delete learnings that are TRULY untouched: never recalled (hit_count=0) AND
  # never even loaded into a session preamble (load_count=0) AND >46 days old.
  # Since v7.15, hit_count is recall-only — a still-loaded-but-never-recalled
  # learning keeps hit_count=0, so requiring load_count=0 too prevents deleting
  # learnings that read-start is actively surfacing. COALESCE handles pre-013 DBs.
  local cond="hit_count = 0 AND COALESCE(load_count,0) = 0 AND ts < datetime('now', '-46 days')"
  local archived
  archived=$(db_exec "SELECT COUNT(*) FROM learnings WHERE $cond;")

  if [ "$archived" -gt 0 ]; then
    db_exec "DELETE FROM learnings WHERE $cond;"
    echo "Archived $archived stale learnings (0 hits, 0 loads, >46 days)"
  else
    echo "No stale learnings to archive"
  fi

  # Report freshness distribution
  echo ""
  echo "Freshness distribution:"
  db_exec "SELECT
    CASE
      WHEN hit_count >= 3 THEN 'high-confidence (' || COUNT(*) || ')'
      WHEN hit_count >= 1 THEN 'reinforced (' || COUNT(*) || ')'
      ELSE 'unvalidated (' || COUNT(*) || ')'
    END as status
  FROM learnings GROUP BY
    CASE WHEN hit_count >= 3 THEN 1 WHEN hit_count >= 1 THEN 2 ELSE 3 END;"
}

cmd_antibody() {
  local pattern="${1:-}"
  [ -z "$pattern" ] && { echo "Usage: agentdb antibody <search_text>"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local safe_pattern
  safe_pattern=$(sql_escape "$pattern")

  echo "## Pattern Antibodies"
  echo "Matching learnings for: $pattern"
  echo ""
  db_exec "SELECT '- [' || type || '] ' || insight || ' (hits: ' || hit_count || ')'
    FROM learnings
    WHERE insight LIKE '%$safe_pattern%' OR domain LIKE '%$safe_pattern%'
    ORDER BY hit_count DESC, ts DESC
    LIMIT 10;"
}

# Relevance recall — surface the learnings that match the CURRENT task, ranked by
# text relevance (FTS5 bm25), not the age-biased session-start score. This is the
# just-in-time retrieval read-start can't do: call it at task-classify with the task
# keywords + touched file names. Bumps hit_count on returned rows only, so hit_count
# becomes a REAL usefulness signal (vs read-start's blanket bump). Falls back to LIKE
# if the FTS index isn't present (DB predates migration 012).
# Locate the cross-project global brain (a metabrain-native DB). Resolution order:
#   1. $AGENTDB_GLOBAL if set.
#   2. Walk up from the project root for an ancestor holding _meta/agentdb/global.db
#      (Aria's layout: project → CodingVault → Vaults/_meta/agentdb/global.db).
# Echoes the path if found+readable, else empty (recall --global degrades to local).
find_global_db() {
  if [ -n "${AGENTDB_GLOBAL:-}" ]; then
    [ -f "$AGENTDB_GLOBAL" ] && echo "$AGENTDB_GLOBAL"
    return 0
  fi
  local d="$PROJECT_ROOT"
  while [ -n "$d" ] && [ "$d" != "/" ]; do
    if [ -f "$d/_meta/agentdb/global.db" ] && [ "$d/_meta/agentdb/global.db" != "$DB" ]; then
      echo "$d/_meta/agentdb/global.db"; return 0
    fi
    d=$(dirname "$d")
  done
  return 0
}

# Emit ranked "<key>@@US@@<line>" rows for a recall query from an arbitrary DB.
# NOTE: the delimiter must be PRINTABLE — sqlite3 >= ~3.45 escapes control chars
# in shell output (char(31) arrives as the two-char string "^_"), which silently
# broke the old \037 delimiter and made every recall return "(no matching learnings)".
# Uses FTS5 (bm25 + boosts) when the DB has a learnings_fts index, else a LIKE
# scan. <tag> is appended to each displayed line (e.g. " [global]"). <writable>=1
# permits an FTS 'rebuild' (local DB only); 0 keeps it strictly read-only (the
# global brain — its FTS is refreshed by the nightly consolidation job, never here).
# Always visibility-filtered (never surfaces human_only/operational to an agent).
_recall_emit() {
  local db="$1" fts_query="$2" like_clause="$3" tag="$4" limit="$5" writable="$6"
  [ -f "$db" ] || return 0
  local has_fts
  has_fts=$(sqlite3 "$db" "SELECT 1 FROM sqlite_master WHERE type='table' AND name='learnings_fts' LIMIT 1;" 2>/dev/null || echo "")
  if [ -n "$has_fts" ]; then
    [ "$writable" = "1" ] && sqlite3 "$db" "INSERT INTO learnings_fts(learnings_fts) VALUES('rebuild');" 2>/dev/null || true
    sqlite3 "$db" "
      SELECT lower(substr(l.insight,1,200)) || '@@US@@' ||
             '- [' || l.type || '] ' || l.insight || '$tag' ||
             CASE WHEN l.evidence IS NOT NULL AND l.evidence != ''
                  THEN '  ↳ ' || substr(l.evidence,1,90) ELSE '' END
      FROM learnings l JOIN learnings_fts f ON f.rowid = l.rowid
      WHERE learnings_fts MATCH '$fts_query'
        AND (l.visibility = 'agent' OR l.visibility IS NULL)
      ORDER BY (
        bm25(learnings_fts)
        - (CASE WHEN l.type IN ('failure','gotcha') THEN 1.5 ELSE 0 END)
        - (MIN(l.hit_count,20) * 0.05)
        - (CASE WHEN julianday('now') - julianday(l.ts) < 14 THEN 0.5 ELSE 0 END)
      ) ASC
      LIMIT $((limit * 5));" 2>/dev/null || true
  elif [ -n "$like_clause" ]; then
    sqlite3 "$db" "
      SELECT lower(substr(insight,1,200)) || '@@US@@' ||
             '- [' || type || '] ' || insight || '$tag' ||
             CASE WHEN evidence IS NOT NULL AND evidence != ''
                  THEN '  ↳ ' || substr(evidence,1,90) ELSE '' END
      FROM learnings
      WHERE ($like_clause)
        AND (visibility = 'agent' OR visibility IS NULL)
      ORDER BY hit_count DESC, ts DESC
      LIMIT $((limit * 5));" 2>/dev/null || true
  fi
}

cmd_recall() {
  # Parse --global (cross-project) out of the args; the rest is the query.
  local use_global=0
  local -a qargs=()
  local a
  for a in "$@"; do
    if [ "$a" = "--global" ]; then use_global=1; else qargs+=("$a"); fi
  done
  local query="${qargs[*]:-}"  # :- guards empty array under set -u on bash 3.2 (macOS)
  [ -z "$query" ] && { echo "Usage: agentdb recall <keywords> [--global]"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  local limit="${RECALL_LIMIT:-8}"

  # Lowercase, keep only [a-z0-9]; drop 1-char tokens + common stopwords so the
  # OR'd query isn't dominated by noise words ("the bug in auth" → bug, auth).
  local terms
  terms=$(printf '%s' "$query" | tr 'A-Z' 'a-z' | tr -cs 'a-z0-9' ' ' \
    | awk 'BEGIN{split("the a an is it to of in on for and or but with this that was are be by at as from not no if then else do does did has have had will would can could should",s," ");for(k in s)stop[s[k]]=1}
           {for(i=1;i<=NF;i++){t=$i;if(length(t)>=2&&!(t in stop))print t}}')
  # Fallback: if hygiene stripped everything (all stopwords), keep raw alnum terms.
  [ -z "$terms" ] && terms=$(printf '%s' "$query" | tr 'A-Z' 'a-z' | tr -cs 'a-z0-9' ' ' | tr ' ' '\n' | awk 'NF')
  [ -z "$terms" ] && { echo "No searchable terms in: $query"; exit 1; }

  # Build the FTS query (phrase-quoted OR — injection-safe, no quotes survive) and a
  # LIKE clause (for DBs without an FTS index). Terms are [a-z0-9] only → quote-safe.
  local fts_query like_clause
  fts_query=$(printf '%s\n' "$terms" | awk 'NF{printf (n++?" OR ":"")"\""$1"\""}')
  like_clause=""
  while IFS= read -r t; do
    [ -z "$t" ] && continue
    like_clause="${like_clause:+$like_clause OR }insight LIKE '%$t%' OR evidence LIKE '%$t%' OR domain LIKE '%$t%'"
  done <<< "$terms"

  # Self-heal local FTS (build it if this DB predates migration 012 / hasn't run
  # preflight this session) so the local path uses bm25 ranking, not LIKE.
  local has_fts
  has_fts=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='learnings_fts' LIMIT 1;" 2>/dev/null || echo "")
  if [ -z "$has_fts" ]; then
    run_pending_migrations "recall:applied_migration" >/dev/null 2>&1 || true
  fi

  # Resolve the global brain only if requested.
  local global_db=""
  if [ "$use_global" = "1" ]; then
    global_db=$(find_global_db || true)
  fi

  echo "## Recall: $query"
  [ -n "$global_db" ] && echo "_(+ global brain: $global_db)_"
  echo ""

  # Collect local first (so a lesson present in both wins as the local copy), then
  # global, then dedup by 200-char insight key and cut to the limit. bm25() can't
  # live inside GROUP BY/an aggregate (the optimizer flattens the subquery →
  # "unable to use function bm25 in the requested context"), so dedup is post-query
  # in awk (printable @@US@@ delimiter — sqlite3 escapes control chars on output,
  # so a raw \037 byte never survives the shell; see _recall_emit note).
  local raw_local raw_global out
  raw_local=$(_recall_emit "$DB" "$fts_query" "$like_clause" "" "$limit" 1)
  raw_global=""
  [ -n "$global_db" ] && raw_global=$(_recall_emit "$global_db" "$fts_query" "$like_clause" " [global]" "$limit" 0)
  out=$(printf '%s\n%s\n' "$raw_local" "$raw_global" | grep -v '^[[:space:]]*$' \
        | awk -F'@@US@@' '!seen[$1]++{print $2}' | head -n "$limit")

  if [ -n "$out" ]; then
    echo "$out"
    # Relevance feedback: bump only the (agent-visible) LOCAL rows this query
    # surfaced. hit_count is exclusively recall-earned (read-start uses load_count),
    # so it's a trustworthy "answered a real task" signal. Never write to the global
    # brain from recall (the consolidation job owns it).
    if [ -n "$has_fts" ] || db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='learnings_fts' LIMIT 1;" 2>/dev/null | grep -q 1; then
      db_exec "UPDATE learnings SET hit_count = hit_count + 1,
                 last_hit = strftime('%Y-%m-%dT%H:%M:%fZ','now')
               WHERE rowid IN (
                 SELECT f.rowid FROM learnings_fts f
                 JOIN learnings l ON l.rowid = f.rowid
                 WHERE learnings_fts MATCH '$fts_query'
                   AND (l.visibility = 'agent' OR l.visibility IS NULL)
                 LIMIT $limit
               );" 2>/dev/null
    fi
  else
    echo "(no matching learnings)"
  fi
}

# === HYPOTHESIS TESTING ===

cmd_hypothesis() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    add)    cmd_hypothesis_add "$@" ;;
    list)   cmd_hypothesis_list "$@" ;;
    update) cmd_hypothesis_update "$@" ;;
    export) cmd_hypothesis_export ;;
    *)      echo "Usage: agentdb hypothesis <add|list|update|export>" >&2; exit 1 ;;
  esac
}

cmd_hypothesis_add() {
  local statement=""
  local domain=""
  local source=""

  # Parse: statement is first positional, then flags
  while [ $# -gt 0 ]; do
    case "$1" in
      --domain) domain="${2:-}"; shift 2 ;;
      --source) source="${2:-}"; shift 2 ;;
      *)
        if [ -z "$statement" ]; then
          statement="$1"
        fi
        shift ;;
    esac
  done

  [ -z "$statement" ] && { echo "Usage: agentdb hypothesis add <statement> [--domain X] [--source Y]" >&2; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  # Auto-generate next H### ID
  local max_num
  max_num=$(db_exec "SELECT COALESCE(MAX(CAST(SUBSTR(id, 2) AS INTEGER)), 0) FROM hypotheses WHERE id LIKE 'H%';" 2>/dev/null || echo "0")
  local next_num=$(( max_num + 1 ))
  local id
  id=$(printf "H%03d" "$next_num")

  local safe_statement safe_domain safe_source
  safe_statement=$(sql_escape "$statement")
  safe_domain=$(sql_escape "$domain")
  safe_source=$(sql_escape "$source")

  db_exec "INSERT INTO hypotheses (id, statement, domain, source) VALUES ('$id', '$safe_statement', '$safe_domain', '$safe_source');"
  echo "Hypothesis: $id — $statement"
}

cmd_hypothesis_list() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local domain=""
  local status=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --domain) domain="${2:-}"; shift 2 ;;
      --status) status="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done

  local where="1=1"
  if [ -n "$domain" ]; then
    local safe_domain
    safe_domain=$(sql_escape "$domain")
    where="$where AND domain='$safe_domain'"
  fi
  if [ -n "$status" ]; then
    local safe_status
    safe_status=$(sql_escape "$status")
    where="$where AND status='$safe_status'"
  fi

  db_exec_opts "-header -column" "
    SELECT id,
           printf('%.2f', confidence) AS conf,
           status,
           COALESCE(domain, '') AS domain,
           substr(statement, 1, 60) AS statement
    FROM hypotheses
    WHERE $where
    ORDER BY created_at DESC;
  "
}

cmd_hypothesis_update() {
  local id="${1:-}"
  [ -z "$id" ] && { echo "Usage: agentdb hypothesis update <id> --status X [--confidence Y]" >&2; exit 1; }
  shift

  local status=""
  local confidence=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --status) status="${2:-}"; shift 2 ;;
      --confidence) confidence="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done

  [ -z "$status" ] && { echo "Usage: agentdb hypothesis update <id> --status X [--confidence Y]" >&2; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local safe_id safe_status
  safe_id=$(sql_escape "$id")
  safe_status=$(sql_escape "$status")

  local set_clause="status='$safe_status', updated_at=strftime('%Y-%m-%dT%H:%M:%fZ','now')"
  if [ -n "$confidence" ]; then
    set_clause="$set_clause, confidence=$confidence"
  fi
  if [ "$status" = "graduated" ]; then
    set_clause="$set_clause, graduated_at=strftime('%Y-%m-%dT%H:%M:%fZ','now')"
  fi

  db_exec "UPDATE hypotheses SET $set_clause WHERE id='$safe_id';"
  echo "Updated: $id → status=$status"
}

cmd_hypothesis_export() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  echo "# Hypothesis Report"
  echo ""
  echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo ""

  local domains
  domains=$(db_exec "SELECT DISTINCT COALESCE(domain, 'uncategorized') FROM hypotheses ORDER BY domain;")

  for d in $domains; do
    local safe_d
    safe_d=$(sql_escape "$d")
    echo "## $d"
    echo ""
    db_exec "
      SELECT '### ' || h.id || ' [' || h.status || ' | conf: ' || printf('%.2f', h.confidence) || ']' || char(10) ||
             h.statement || char(10) ||
             'Evidence: ' || h.evidence_for || ' for, ' || h.evidence_against || ' against' || char(10) ||
             'Experiments: ' || (SELECT COUNT(*) FROM experiments WHERE hypothesis_id = h.id) || char(10)
      FROM hypotheses h
      WHERE COALESCE(h.domain, 'uncategorized') = '$safe_d'
      ORDER BY h.confidence DESC;
    "
    echo ""
  done
}

cmd_experiment() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    add)     cmd_experiment_add "$@" ;;
    verdict) cmd_experiment_verdict "$@" ;;
    list)    cmd_experiment_list "$@" ;;
    *)       echo "Usage: agentdb experiment <add|verdict|list>" >&2; exit 1 ;;
  esac
}

cmd_experiment_add() {
  local hypothesis_id="${1:-}"
  local method="${2:-}"
  local measurement="${3:-}"
  shift 3 2>/dev/null || true

  local pass_criteria=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --pass-criteria) pass_criteria="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done

  [ -z "$hypothesis_id" ] || [ -z "$method" ] || [ -z "$measurement" ] && {
    echo "Usage: agentdb experiment add <hypothesis_id> <method> <measurement> [--pass-criteria X]" >&2
    exit 1
  }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  # Verify hypothesis exists
  local exists
  exists=$(db_exec "SELECT 1 FROM hypotheses WHERE id='$(sql_escape "$hypothesis_id")' LIMIT 1;" 2>/dev/null || echo "")
  [ -z "$exists" ] && { echo "Error: hypothesis $hypothesis_id not found" >&2; exit 1; }

  # Auto-generate next EXP-### ID
  local max_num
  max_num=$(db_exec "SELECT COALESCE(MAX(CAST(SUBSTR(id, 5) AS INTEGER)), 0) FROM experiments WHERE id LIKE 'EXP-%';" 2>/dev/null || echo "0")
  local next_num=$(( max_num + 1 ))
  local id
  id=$(printf "EXP-%03d" "$next_num")

  local safe_hid safe_method safe_measurement safe_criteria
  safe_hid=$(sql_escape "$hypothesis_id")
  safe_method=$(sql_escape "$method")
  safe_measurement=$(sql_escape "$measurement")
  safe_criteria=$(sql_escape "$pass_criteria")

  db_exec "INSERT INTO experiments (id, hypothesis_id, method, measurement, pass_criteria) VALUES ('$id', '$safe_hid', '$safe_method', '$safe_measurement', '$safe_criteria');"
  echo "Experiment: $id → $hypothesis_id"
}

cmd_experiment_verdict() {
  local exp_id="${1:-}"
  local verdict="${2:-}"
  local evidence="${3:-}"

  [ -z "$exp_id" ] || [ -z "$verdict" ] || [ -z "$evidence" ] && {
    echo "Usage: agentdb experiment verdict <exp_id> <supports|refutes|inconclusive> <evidence>" >&2
    exit 1
  }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  # Validate verdict value
  case "$verdict" in
    supports|refutes|inconclusive) ;;
    *) echo "Error: verdict must be supports|refutes|inconclusive" >&2; exit 1 ;;
  esac

  local safe_id safe_verdict safe_evidence
  safe_id=$(sql_escape "$exp_id")
  safe_verdict=$(sql_escape "$verdict")
  safe_evidence=$(sql_escape "$evidence")

  # Update the experiment
  db_exec "UPDATE experiments SET verdict='$safe_verdict', evidence='$safe_evidence', result='$safe_evidence' WHERE id='$safe_id';"

  # Get parent hypothesis ID
  local hyp_id
  hyp_id=$(db_exec "SELECT hypothesis_id FROM experiments WHERE id='$safe_id';" 2>/dev/null)
  [ -z "$hyp_id" ] && { echo "Error: experiment $exp_id not found" >&2; exit 1; }

  local safe_hid
  safe_hid=$(sql_escape "$hyp_id")

  # Update parent hypothesis based on verdict
  case "$verdict" in
    supports)
      db_exec "
        UPDATE hypotheses SET
          evidence_for = evidence_for + 1,
          confidence = MIN(1.0, confidence + (1.0 - confidence) * 0.25),
          status = CASE WHEN status = 'unproven' THEN 'testing' ELSE status END,
          updated_at = strftime('%Y-%m-%dT%H:%M:%fZ','now')
        WHERE id = '$safe_hid';
      "
      ;;
    refutes)
      db_exec "
        UPDATE hypotheses SET
          evidence_against = evidence_against + 1,
          confidence = MAX(0.0, confidence - confidence * 0.3),
          status = CASE WHEN status = 'unproven' THEN 'testing' ELSE status END,
          updated_at = strftime('%Y-%m-%dT%H:%M:%fZ','now')
        WHERE id = '$safe_hid';
      "
      ;;
    inconclusive)
      db_exec "
        UPDATE hypotheses SET
          status = CASE WHEN status = 'unproven' THEN 'testing' ELSE status END,
          updated_at = strftime('%Y-%m-%dT%H:%M:%fZ','now')
        WHERE id = '$safe_hid';
      "
      ;;
  esac

  local new_conf
  new_conf=$(db_exec "SELECT printf('%.2f', confidence) FROM hypotheses WHERE id='$safe_hid';" 2>/dev/null)
  echo "Verdict: $exp_id → $verdict ($hyp_id confidence: $new_conf)"
}

cmd_experiment_list() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  local hypothesis_id="${1:-}"

  if [ -n "$hypothesis_id" ]; then
    local safe_hid
    safe_hid=$(sql_escape "$hypothesis_id")
    db_exec_opts "-header -column" "
      SELECT id, hypothesis_id, COALESCE(verdict, 'pending') AS verdict, substr(method, 1, 40) AS method, substr(COALESCE(evidence, ''), 1, 40) AS evidence
      FROM experiments
      WHERE hypothesis_id = '$safe_hid'
      ORDER BY created_at DESC;
    "
  else
    db_exec_opts "-header -column" "
      SELECT id, hypothesis_id, COALESCE(verdict, 'pending') AS verdict, substr(method, 1, 40) AS method, substr(COALESCE(evidence, ''), 1, 40) AS evidence
      FROM experiments
      ORDER BY created_at DESC;
    "
  fi
}

# === CO-CHANGE GRAPH ===
cmd_co_change() {
  local file="${1:-}"
  local limit="${2:-10}"

  [ -z "$file" ] && { echo "Usage: agentdb co-change <file> [limit]"; exit 1; }
  validate_int "$limit" "limit"

  local project_root
  project_root=$(find_project_root)

  echo "## Co-Change Graph: $file"
  echo "Files frequently modified alongside $file:"
  echo ""

  # Mine git log for co-modifications
  # For each commit that touched $file, list other files changed
  git -C "$project_root" log --pretty=format:"%H" --follow -- "$file" 2>/dev/null | head -50 | while read -r commit; do
    git -C "$project_root" diff-tree --no-commit-id --name-only -r "$commit" 2>/dev/null
  done | grep -v "^$(basename "$file")$" | sort | uniq -c | sort -rn | head -"$limit" | while read -r count cofile; do
    echo "- $cofile ($count co-changes)"
  done
}

