#!/bin/bash
# KERNEL AgentDB CLI
# Every agent reads on start, writes on end. No exceptions.
#
# USAGE:
#   agentdb init                    # Initialize per-project DB
#   agentdb read-start              # Generic top-N learnings (session start)
#   agentdb recall <keywords>       # RELEVANCE search — the right learning for THIS task (FTS5)
#   agentdb write-end <json>        # Checkpoint before stopping
#   agentdb learn <type> <insight>  # Record learning
#   agentdb contract <json>         # Create contract
#   agentdb verdict <pass|fail> <evidence>  # QA result
#   agentdb query <sql>             # Raw query
#   agentdb status                  # DB health, counts, last checkpoint time
#   agentdb prune                   # Delete old checkpoints (keep last 10)
#   agentdb export                  # Dump learnings to markdown
#   agentdb recent                  # Show last 5 checkpoints
#   agentdb inject-context <type>   # Build agent-specific context slice
#   agentdb health                  # Check system health
#   agentdb trace <json>            # Record GEPA execution trace
#   agentdb decay                   # Archive stale learnings
#   agentdb antibody <text>         # Search IMMUNE pattern antibodies

set -euo pipefail

# Dependency check
command -v sqlite3 >/dev/null 2>&1 || { echo "Error: sqlite3 required but not found" >&2; exit 1; }

# Find project root (where .claude/ or _meta/ exists)
find_project_root() {
  # Explicit override wins — pin the DB location to dodge the PWD-walk foot-gun
  # when agents run from sub-dirs or temp dirs (D9/R7).
  if [ -n "${AGENTDB_ROOT:-}" ]; then
    echo "$AGENTDB_ROOT"
    return
  fi
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/_meta" ] || [ -d "$dir/.claude" ]; then
      echo "$dir"
      return
    fi
    dir=$(dirname "$dir")
  done
  # Fallback: nothing found on the walk up. Warn — this is how orphan DBs get
  # created in whatever PWD happened to be (the "VaultsS" typo orphan, etc.).
  echo "agentdb: warning — no _meta/ or .claude/ above $PWD; using PWD (set AGENTDB_ROOT to pin)" >&2
  echo "$PWD"
}

PROJECT_ROOT=$(find_project_root)
DB_DIR="$PROJECT_ROOT/_meta/agentdb"
DB="$DB_DIR/agent.db"
SCHEMA_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"

# === SECURITY: SQL escaping ===
# Escape single quotes for safe SQL insertion
sql_escape() {
  printf '%s' "$1" | sed "s/'/''/g"
}

# JSON-safe escaping (backslashes then double quotes)
json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

# Integer validation for numeric SQL parameters
validate_int() {
  local val="$1"
  local name="${2:-value}"
  [[ "$val" =~ ^[0-9]+$ ]] || { echo "Error: $name must be integer" >&2; exit 1; }
}

# Execute sqlite3 with busy_timeout
db_exec() {
  sqlite3 "$DB" <<EOF
.timeout 5000
$1
EOF
}

# Execute sqlite3 with options and busy_timeout
db_exec_opts() {
  local opts="$1"
  shift
  # shellcheck disable=SC2086
  sqlite3 $opts "$DB" <<EOF
.timeout 5000
$1
EOF
}

# Ensure the soft-delete cache columns exist on the LOCAL learnings table
# (migration 014, design 3.7). SQLite has no ADD COLUMN IF NOT EXISTS, so this
# PRAGMA-gates the add. Single source of truth for the archived_at/archived_reason
# columns: cmd_preflight, cmd_read_start, cmd_recall, and cmd_decay all call this
# so the "WHERE archived_at IS NULL" filter is safe regardless of preflight timing.
# Idempotent + cheap (one PRAGMA select), best-effort (never fails the caller).
_ensure_softdelete_cols() {
  [ -f "$DB" ] || return 0
  local has
  has=$(db_exec "SELECT 1 FROM pragma_table_info('learnings') WHERE name='archived_at' LIMIT 1;" 2>/dev/null || echo "")
  if [ -z "$has" ]; then
    db_exec "ALTER TABLE learnings ADD COLUMN archived_at TEXT;" 2>/dev/null || true
    db_exec "ALTER TABLE learnings ADD COLUMN archived_reason TEXT;" 2>/dev/null || true
  fi
  return 0
}

# Return a SQL literal for a text value: '<escaped>' for a non-empty string, or
# bare NULL for an empty one (absence = UNKNOWN, never an empty-string fact; the
# null-semantics contract, design 5.2).
_sql_text() {
  if [ -z "${1:-}" ]; then printf 'NULL'; else printf "'%s'" "$(sql_escape "$1")"; fi
}

# Append one row to the memory-lifecycle event spine (memory_events, design 2.1).
# BEST-EFFORT BY CONTRACT: a failed emit prints a LOUD warning to stderr and
# returns 0, so instrumentation can never break a learn/recall/decay/read-start.
# Never UPDATEs or DELETEs (append-only). event_id is globally unique across dbs.
# Args (positional; empty = SQL NULL):
#   1 kind (required)   2 subject_id   3 reason   4 payload_json
#   5 actor             6 object_id    7 inference_method
#   8 source_db         9 source_row_id  10 import_batch_id
emit_memory_event() {
  local kind="${1:-}" subject_id="${2:-}" reason="${3:-}" payload="${4:-}"
  local actor="${5:-}" object_id="${6:-}" inference_method="${7:-}"
  local source_db="${8:-}" source_row_id="${9:-}" import_batch_id="${10:-}"

  if [ -z "$kind" ]; then
    echo "[agentdb] emit_memory_event: kind is required; event NOT recorded" >&2
    return 0
  fi
  # Advisory known-verb validation (open vocabulary: a new verb is accepted, a
  # typo in a known verb is surfaced). Never a hard reject (design 2.2).
  case "$kind" in
    created|updated|imported|merged|retrieved|surfaced|used|ignored|reinforced|graduated|archived|resurrected|domain_changed|superseded) ;;
    *) echo "[agentdb] emit_memory_event: '$kind' is not a known memory verb (recording anyway; open vocabulary)" >&2 ;;
  esac

  # actor defaults to the session id if the caller left it empty.
  [ -z "$actor" ] && actor="${AGENTDB_SESSION_ID:-${CLAUDE_SESSION_ID:-}}"

  local db_short eid
  db_short=$(basename "$PROJECT_ROOT" 2>/dev/null | tr -cs 'a-zA-Z0-9' '-' | cut -c1-16)
  [ -z "$db_short" ] && db_short="db"
  eid="${db_short}-$(date -u +%Y%m%d%H%M%S)-$$-${RANDOM}${RANDOM}"

  if db_exec "INSERT INTO memory_events
      (event_id, kind, actor, source_db, source_row_id, import_batch_id,
       subject_id, object_id, reason, inference_method, payload)
      VALUES ('$eid', '$(sql_escape "$kind")', $(_sql_text "$actor"),
        $(_sql_text "$source_db"), $(_sql_text "$source_row_id"), $(_sql_text "$import_batch_id"),
        $(_sql_text "$subject_id"), $(_sql_text "$object_id"), $(_sql_text "$reason"),
        $(_sql_text "$inference_method"), $(_sql_text "$payload"));" 2>/dev/null; then
    return 0
  else
    echo "[agentdb] WARNING: failed to record memory_event (kind=$kind subject=${subject_id:-none}); memory path unaffected, but this observation was LOST. Run 'agentdb preflight' to self-heal the memory_events table." >&2
    return 0
  fi
}

# === COMMANDS ===

# Apply every migration not yet recorded in _migrations, in filename order.
# Idempotent on two levels: the marker check skips already-applied migrations,
# and each migration file is itself written to be safe to re-run (CREATE TABLE
# IF NOT EXISTS / INSERT OR IGNORE / column-adds delegated to preflight).
# Shared by cmd_init (fresh DBs) AND cmd_preflight (existing DBs self-heal every
# session start) — this is the one place migrations are applied.
# Echoes "<label>: <name>" per applied migration. Sets MIGRATIONS_APPLIED count.
#
# Arg 2 "force": re-read EVERY migration regardless of its _migrations marker.
# Used by the table-loss repair path (Check 2): a table created by a migration
# (e.g. `events` from 003) can drift away while its marker stays recorded, and a
# marker-gated pass would skip the migration that recreates it — looping forever
# on "missing_table" + phantom repairs. Force-reading is safe because every
# migration file is idempotent (verified: IF NOT EXISTS / INSERT OR IGNORE /
# delegated column-adds). Force mode is silent and does not touch
# MIGRATIONS_APPLIED — it is recovery, not new-migration application.
run_pending_migrations() {
  local label="${1:-Applied migration}"
  local force="${2:-}"
  MIGRATIONS_APPLIED=0
  [ -d "$SCHEMA_DIR/migrations" ] || return 0
  for migration in "$SCHEMA_DIR/migrations"/*.sql; do
    [ -f "$migration" ] || continue
    [[ "$migration" == *.down.sql ]] && continue
    local name
    name=$(basename "$migration" .sql)
    if [ "$force" != "force" ]; then
      local applied
      applied=$(db_exec "SELECT 1 FROM _migrations WHERE name='$name' LIMIT 1;" 2>/dev/null || echo "")
      [ -n "$applied" ] && continue
    fi
    if sqlite3 "$DB" ".timeout 5000" ".read $migration" 2>/dev/null; then
      if [ "$force" != "force" ]; then
        echo "$label: $name"
        MIGRATIONS_APPLIED=$((MIGRATIONS_APPLIED + 1))
      fi
    else
      echo "$label: $name FAILED (see migration file)" >&2
    fi
  done
  return 0
}

cmd_init() {
  mkdir -p "$DB_DIR"

  # Fresh clone with a committed JSON snapshot but no live .db → rehydrate the brain
  # from it instead of starting empty. Guard against the import-json → cmd_init recursion.
  if [ ! -f "$DB" ] && [ -f "$DB_DIR/agent.db.json" ] && [ -z "${_AGENTDB_IMPORTING:-}" ]; then
    echo "init: rehydrating from snapshot agent.db.json" >&2
    cmd_import_json "$DB_DIR/agent.db.json" >&2 2>&1 || true
    [ -f "$DB" ] && { echo "DB exists: $DB"; return 0; }
  fi

  local created_new=false

  # Apply base schema if DB doesn't exist
  if [ ! -f "$DB" ]; then
    created_new=true
    if [ -f "$SCHEMA_DIR/schema.sql" ]; then
      sqlite3 "$DB" "PRAGMA busy_timeout=5000;" ".read $SCHEMA_DIR/schema.sql"
    else
      echo "Error: schema.sql not found at $SCHEMA_DIR/schema.sql" >&2
      echo "Cannot initialize database without schema definition." >&2
      exit 1
    fi
  fi

  run_pending_migrations "Applied migration"

  if [ "$created_new" = true ]; then
    echo "Initialized: $DB"
  else
    echo "DB exists: $DB"
  fi
}

cmd_preflight() {
  # Validate local environment and DB schema integrity
  # Called by session-start hook to catch drift before it causes errors
  local warnings=0
  local repairs=0

  # Check 1: DB exists
  if [ ! -f "$DB" ]; then
    echo "preflight:init — no database found, initializing"
    cmd_init >/dev/null
    repairs=$((repairs + 1))
  fi

  # Check 2: Required tables exist
  local required_tables="learnings context errors _migrations events memory_events"
  for table in $required_tables; do
    local exists
    exists=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='$table' LIMIT 1;" 2>/dev/null || echo "")
    if [ -z "$exists" ]; then
      echo "preflight:missing_table — $table not found, applying schema"
      # Re-apply schema (all CREATE TABLE IF NOT EXISTS, safe to re-run)
      if [ -f "$SCHEMA_DIR/schema.sql" ]; then
        sqlite3 "$DB" ".timeout 5000" ".read $SCHEMA_DIR/schema.sql" >/dev/null 2>&1 || true
      fi
      # Re-run migrations only if _migrations table exists (avoid circular dep)
      local has_migrations
      has_migrations=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='_migrations' LIMIT 1;" 2>/dev/null || echo "")
      if [ -n "$has_migrations" ]; then
        # force: a dropped migration-table keeps its marker, so re-read every
        # migration to recreate it (idempotent). Marker-gated pass would skip it.
        run_pending_migrations "preflight:applied_migration" force >/dev/null
      fi
      repairs=$((repairs + 1))
      # no break — repair every missing table, not just the first
    fi
  done

  # Check 3: learnings schema has all expected columns
  local expected_cols="id ts type insight evidence domain hit_count load_count last_hit visibility sensitivity"
  for col in $expected_cols; do
    local has_col
    has_col=$(db_exec "SELECT 1 FROM pragma_table_info('learnings') WHERE name='$col' LIMIT 1;" 2>/dev/null || echo "")
    if [ -z "$has_col" ]; then
      echo "preflight:missing_column — learnings.$col not found, adding"
      # Determine type for the missing column
      case "$col" in
        hit_count)   db_exec "ALTER TABLE learnings ADD COLUMN hit_count INTEGER DEFAULT 0;" 2>/dev/null || true ;;
        load_count)  db_exec "ALTER TABLE learnings ADD COLUMN load_count INTEGER DEFAULT 0;" 2>/dev/null || true ;;
        last_hit)    db_exec "ALTER TABLE learnings ADD COLUMN last_hit TEXT;" 2>/dev/null || true ;;
        domain)      db_exec "ALTER TABLE learnings ADD COLUMN domain TEXT;" 2>/dev/null || true ;;
        visibility)  db_exec "ALTER TABLE learnings ADD COLUMN visibility TEXT DEFAULT 'agent';" 2>/dev/null || true ;;
        sensitivity) db_exec "ALTER TABLE learnings ADD COLUMN sensitivity TEXT DEFAULT 'low';" 2>/dev/null || true ;;
        *)           echo "preflight:error — unknown column $col, manual fix required"; warnings=$((warnings + 1)); continue ;;
      esac
      repairs=$((repairs + 1))
    fi
  done

  # Check 3b: errors schema has domain column (migration 008, delegated here —
  # SQLite has no ADD COLUMN IF NOT EXISTS, so we PRAGMA-gate the add).
  local has_errors_domain
  has_errors_domain=$(db_exec "SELECT 1 FROM pragma_table_info('errors') WHERE name='domain' LIMIT 1;" 2>/dev/null || echo "")
  if [ -z "$has_errors_domain" ]; then
    echo "preflight:missing_column — errors.domain not found, adding"
    db_exec "ALTER TABLE errors ADD COLUMN domain TEXT;" 2>/dev/null || true
    repairs=$((repairs + 1))
  fi

  # Check 3c: learnings has the soft-delete cache columns (migration 014,
  # design 3.7). Delegated to a single guarded helper (SQLite has no ADD COLUMN
  # IF NOT EXISTS), shared with read-start/recall/decay so the archived filter is
  # always safe. Silent + idempotent: only ALTERs when the column is absent.
  local has_archived
  has_archived=$(db_exec "SELECT 1 FROM pragma_table_info('learnings') WHERE name='archived_at' LIMIT 1;" 2>/dev/null || echo "")
  if [ -z "$has_archived" ]; then
    echo "preflight:missing_column learnings.archived_at not found, adding (migration 014)"
    _ensure_softdelete_cols
    repairs=$((repairs + 1))
  fi

  # Check 4: Apply any pending migrations (not just warn). This is the self-heal
  # path for every existing DB — migrations only ran on fresh init before, so DBs
  # created on an older version never received later migrations. Idempotency is
  # guaranteed by run_pending_migrations + per-file re-run safety.
  run_pending_migrations "preflight:applied_migration"
  if [ "${MIGRATIONS_APPLIED:-0}" -gt 0 ]; then
    repairs=$((repairs + MIGRATIONS_APPLIED))
  fi

  # Check 5: DB is writable (not corrupted or locked)
  local write_test
  write_test=$(db_exec "PRAGMA integrity_check;" 2>/dev/null | head -1 || echo "fail")
  if [ "$write_test" != "ok" ]; then
    echo "preflight:corruption — integrity check failed: $write_test"
    warnings=$((warnings + 1))
  fi

  # Check 6: schema.sql exists (needed for future init/migrations)
  if [ ! -f "$SCHEMA_DIR/schema.sql" ]; then
    echo "preflight:missing_schema — schema.sql not found at $SCHEMA_DIR"
    warnings=$((warnings + 1))
  fi

  # Check 7: DB bloat (>5MB is suspicious for a metadata store)
  local db_bytes
  db_bytes=$(stat -f%z "$DB" 2>/dev/null || stat -c%s "$DB" 2>/dev/null || echo "0")
  if [ "$db_bytes" -gt 5242880 ]; then
    local db_mb=$(( db_bytes / 1048576 ))
    echo "preflight:bloat — agent.db is ${db_mb}MB (consider: agentdb prune all)"
    warnings=$((warnings + 1))
  fi

  # Check 8: Orphan contracts (>48h with no verdict)
  local orphan_count
  orphan_count=$(db_exec "
    SELECT COUNT(*) FROM context
    WHERE type='contract'
      AND ts < datetime('now', '-2 days')
      AND contract_id NOT IN (
        SELECT COALESCE(contract_id, '') FROM context WHERE type='verdict'
      );
  " 2>/dev/null || echo "0")
  if [ "$orphan_count" -gt 0 ]; then
    echo "preflight:orphan_contracts — $orphan_count contract(s) >48h with no verdict (close with: agentdb contract close --stale)"
    warnings=$((warnings + 1))
  fi

  # Check 9: Stale learnings ratio (>50% with 0 hits and >14 days old)
  local total_learnings stale_learnings
  total_learnings=$(db_exec "SELECT COUNT(*) FROM learnings;" 2>/dev/null || echo "0")
  if [ "$total_learnings" -gt 5 ]; then
    stale_learnings=$(db_exec "
      SELECT COUNT(*) FROM learnings
      WHERE hit_count = 0 AND ts < datetime('now', '-14 days');
    " 2>/dev/null || echo "0")
    if [ $(( stale_learnings * 100 / total_learnings )) -gt 50 ]; then
      echo "preflight:stale_learnings — $stale_learnings/$total_learnings learnings never reinforced (consider pruning)"
      warnings=$((warnings + 1))
    fi
  fi

  # Summary
  if [ $warnings -eq 0 ] && [ $repairs -eq 0 ]; then
    echo "preflight:ok"
  else
    echo "preflight:done — $repairs repairs, $warnings warnings"
  fi
  return 0
}

cmd_read_start() {
  local mode="${1:---weighted}"
  [ ! -f "$DB" ] && cmd_init >/dev/null

  echo "# AgentDB Context"

  case "$mode" in
    --full)
      # Legacy: load everything (~23K tokens). Use for deep debugging.
      echo "## Mode: full (all learnings)"
      echo ""
      echo "## Failures (AVOID THESE)"
      db_exec "SELECT '- [' || type || '] ' || insight FROM learnings WHERE type IN ('failure','gotcha') ORDER BY hit_count DESC, ts DESC;" 2>/dev/null || echo "None"
      echo ""
      echo "## Patterns"
      db_exec "SELECT '- ' || insight FROM learnings WHERE type='pattern' ORDER BY hit_count DESC, ts DESC;" 2>/dev/null || echo "None"
      echo ""
      echo "## Preferences"
      db_exec "SELECT '- ' || insight FROM learnings WHERE type='preference' ORDER BY ts DESC;" 2>/dev/null || echo "None"
      # Telemetry only: bump load_count (NOT hit_count — read-start dumps are not
      # relevance feedback; only recall earns a hit_count bump). See migration 013.
      db_exec "UPDATE learnings SET load_count = load_count + 1;" 2>/dev/null
      ;;

    --summary)
      # Minimal: top 10 by score (~400 tokens). Use in tight context.
      echo "## Mode: summary (top 10)"
      echo ""
      db_exec "
        SELECT '- [' || type || '] ' || insight FROM (
          SELECT type, insight,
            (hit_count * 10)
            + (CASE WHEN type IN ('failure','gotcha') THEN 50 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 7 THEN 10 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 14 THEN 5 ELSE 0 END)
            AS score
          FROM learnings ORDER BY score DESC LIMIT 10
        );
      " 2>/dev/null || echo "None"
      db_exec "UPDATE learnings SET load_count = load_count + 1 WHERE id IN (
        SELECT id FROM (
          SELECT id,
            (hit_count * 10) + (CASE WHEN type IN ('failure','gotcha') THEN 50 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 7 THEN 10 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 14 THEN 5 ELSE 0 END) AS score
          FROM learnings ORDER BY score DESC LIMIT 10
        )
      );" 2>/dev/null
      ;;

    --tiered)
      # Quality: hot + warm + cold (~8K tokens). Use for tier 3 contracts.
      echo "## Mode: tiered (hot + warm + cold)"
      echo ""
      echo "### Hot (high-hit, proven valuable)"
      db_exec "SELECT '- ' || insight FROM learnings WHERE hit_count > 5 ORDER BY hit_count DESC;" 2>/dev/null || echo "None"
      echo ""
      echo "### Warm (all failures + gotchas)"
      db_exec "SELECT '- [' || type || '] ' || insight FROM learnings WHERE type IN ('failure','gotcha') AND hit_count <= 5 ORDER BY hit_count DESC, ts DESC;" 2>/dev/null || echo "None"
      echo ""
      echo "### Cold (last 7 days)"
      db_exec "SELECT '- ' || insight FROM learnings WHERE hit_count <= 5 AND type NOT IN ('failure','gotcha') AND julianday('now') - julianday(ts) < 7 ORDER BY ts DESC;" 2>/dev/null || echo "None"
      # Telemetry only: bump load_count for the dumped tier set (see migration 013).
      db_exec "UPDATE learnings SET load_count = load_count + 1 WHERE hit_count > 5 OR type IN ('failure','gotcha') OR julianday('now') - julianday(ts) < 7;" 2>/dev/null
      ;;

    --weighted|*)
      # Default: WEIGHTED-75 (~3.4K tokens, 84% failure coverage). H078 graduated.
      # Score = (hit_count * 10) + (failure_bonus * 50) + (recency_7d * 10) + (recency_14d * 5)
      echo "## Mode: weighted-75"
      echo ""
      db_exec "
        SELECT '- [' || type || '] ' || insight FROM (
          SELECT type, insight,
            (hit_count * 10)
            + (CASE WHEN type IN ('failure','gotcha') THEN 50 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 7 THEN 10 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 14 THEN 5 ELSE 0 END)
            AS score
          FROM learnings ORDER BY score DESC LIMIT 75
        );
      " 2>/dev/null || echo "None"
      # Telemetry only: bump load_count for the dumped set (see migration 013).
      db_exec "UPDATE learnings SET load_count = load_count + 1 WHERE id IN (
        SELECT id FROM (
          SELECT id,
            (hit_count * 10) + (CASE WHEN type IN ('failure','gotcha') THEN 50 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 7 THEN 10 ELSE 0 END)
            + (CASE WHEN julianday('now') - julianday(ts) < 14 THEN 5 ELSE 0 END) AS score
          FROM learnings ORDER BY score DESC LIMIT 75
        )
      );" 2>/dev/null
      ;;
  esac

  echo ""
  echo "## Recent Errors"
  db_exec "SELECT '- [' || tool || '] ' || substr(error, 1, 120) FROM errors ORDER BY ts DESC LIMIT 5;" 2>/dev/null || echo "None"
  echo ""

  # Error replay detection: warn if recent errors match known failure patterns
  local replay_warnings
  replay_warnings=$(db_exec "
    SELECT DISTINCT '- REPLAY RISK: \"' || substr(e.error, 1, 60) || '\" matches: ' || l.insight
    FROM errors e
    JOIN learnings l ON l.type = 'failure'
    WHERE e.ts > datetime('now', '-24 hours')
    AND (
      e.error LIKE '%' || substr(l.insight, 1, 30) || '%'
      OR l.insight LIKE '%' || REPLACE(REPLACE(e.error, CHAR(10), ' '), CHAR(13), ' ') || '%'
      OR (e.tool != 'unknown' AND l.domain IS NOT NULL AND e.tool = l.domain)
    )
    LIMIT 3;
  " 2>/dev/null || echo "")
  if [ -n "$replay_warnings" ]; then
    echo "## Replay Detection"
    echo "$replay_warnings"
    echo ""
  fi

  echo "## Active Contract"
  db_exec "SELECT content FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 1;" 2>/dev/null || echo "None"
  echo ""

  echo "## Last Checkpoint"
  db_exec "SELECT content FROM context WHERE type='checkpoint' ORDER BY ts DESC LIMIT 1;" 2>/dev/null || echo "None"
}

cmd_write_end() {
  local content="${1:-}"
  local agent="${2:-orchestrator}"

  [ -z "$content" ] && { echo "Usage: agentdb write-end <json> [agent]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_content safe_agent
  safe_content=$(sql_escape "$content")
  safe_agent=$(sql_escape "$agent")

  local id="CP-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  db_exec "INSERT INTO context (id, type, agent, content) VALUES ('$id', 'checkpoint', '$safe_agent', '$safe_content');"
  echo "Checkpoint: $id"

  # Refresh the committable JSON snapshot so the session-end / pre-compact commit picks
  # up text, never the raw binary .db. Best-effort: never let it fail a checkpoint.
  if command -v jq >/dev/null 2>&1; then
    cmd_export_json >/dev/null 2>&1 || true
  fi
}

cmd_learn() {
  # Usage: agentdb learn <type> <insight> [evidence] [domain]
  #        agentdb learn <type> <insight> [evidence] [domain] --visibility <agent|human_only|operational> --sensitivity <low|medium|high>
  local type="" insight="" evidence="" domain="" visibility="agent" sensitivity="low"
  local positional=()

  # Parse mixed positional + flag arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --visibility) visibility="${2:-agent}"; shift 2 ;;
      --sensitivity) sensitivity="${2:-low}"; shift 2 ;;
      --domain) domain="${2:-}"; shift 2 ;;
      --evidence) evidence="${2:-}"; shift 2 ;;
      -*) shift ;;  # skip unknown flags
      *) positional+=("$1"); shift ;;
    esac
  done

  type="${positional[0]:-}"
  insight="${positional[1]:-}"
  [[ -z "$evidence" ]] && evidence="${positional[2]:-}"
  [[ -z "$domain" ]] && domain="${positional[3]:-}"

  # Auto-infer domain from PWD if not explicitly provided
  if [ -z "$domain" ]; then
    domain=$(basename "$PWD" 2>/dev/null || echo "general")
    [ -z "$domain" ] && domain="general"
  fi

  [ -z "$type" ] || [ -z "$insight" ] && {
    echo "Usage: agentdb learn <type> <insight> [evidence] [domain] [--visibility agent|human_only|operational] [--sensitivity low|medium|high]"
    exit 1
  }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  # Validate enums — warn on operational (never auto-surfaced; human-only)
  if [[ "$visibility" == "operational" ]]; then
    echo "[agentdb] WARNING: visibility=operational — this learning will NOT be surfaced to agents automatically." >&2
    echo "[agentdb]   Use --visibility agent (default) for learnings agents should recall." >&2
  fi
  [[ "$visibility" =~ ^(agent|human_only|operational)$ ]] || visibility="agent"
  [[ "$sensitivity" =~ ^(low|medium|high)$ ]] || sensitivity="low"

  # Escape all inputs
  local safe_type safe_insight safe_evidence safe_domain safe_visibility safe_sensitivity
  safe_type=$(sql_escape "$type")
  safe_insight=$(sql_escape "$insight")
  safe_evidence=$(sql_escape "$evidence")
  safe_domain=$(sql_escape "$domain")
  safe_visibility=$(sql_escape "$visibility")
  safe_sensitivity=$(sql_escape "$sensitivity")

  # Dedup: if similar learning exists, reinforce instead of duplicating
  local safe_substr
  safe_substr=$(sql_escape "${insight:0:40}")
  local existing
  existing=$(db_exec "SELECT id FROM learnings WHERE insight LIKE '%${safe_substr}%' AND type='$safe_type' LIMIT 1;" 2>/dev/null || echo "")
  if [ -n "$existing" ]; then
    db_exec "UPDATE learnings SET hit_count = hit_count + 1 WHERE id='$existing';"
    echo "Reinforced: [$type] (existing: $existing)"
    return
  fi

  local id="LRN-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  db_exec "INSERT INTO learnings (id, type, insight, evidence, domain, visibility, sensitivity)
    VALUES ('$id', '$safe_type', '$safe_insight', '$safe_evidence', '$safe_domain', '$safe_visibility', '$safe_sensitivity');"
  echo "Learned: [$type] $insight"
}

cmd_active() {
  # agentdb active [get]              — show current active.md
  # agentdb active set "task" [tier]  — update task in active.md
  local subcmd="${1:-get}"
  local active_path
  active_path="$(find_project_root)/_meta/context/active.md"

  case "$subcmd" in
    get)
      if [ -f "$active_path" ]; then
        cat "$active_path"
      else
        echo "No active session (active.md not found)"
      fi
      ;;
    set)
      local task="${2:-unknown task}"
      local tier="${3:-1}"
      local branch
      branch=$(git -C "$(find_project_root)" symbolic-ref --short -q HEAD 2>/dev/null || echo "unknown")
      mkdir -p "$(dirname "$active_path")"
      cat > "$active_path" <<EOF
# Active Session
updated: $(date -u +%Y-%m-%dT%H:%M:%SZ)
task: $task
branch: $branch
tier: $tier
status: active
EOF
      echo "Active session set: $task"
      ;;
    clear)
      if [ -f "$active_path" ]; then
        sed -i.bak 's/^status: .*/status: ended/' "$active_path" && rm -f "${active_path}.bak"
        echo "Active session cleared"
      fi
      ;;
    *)
      echo "Usage: agentdb active [get|set <task> [tier]|clear]"
      ;;
  esac
}

cmd_done() {
  # Convenience wrapper: agentdb done "what I did" "what's next"
  # Human-friendly alternative to write-end with JSON syntax.
  local did="${1:-session ended}"
  local next="${2:-}"
  local json
  json="{\"did\":\"$(json_escape "$did")\",\"next\":\"$(json_escape "$next")\"}"
  cmd_write_end "$json"
  cmd_active clear 2>/dev/null || true
  echo "Session checkpoint written."
}

cmd_contract() {
  local subcmd="${1:-}"

  case "$subcmd" in
    close)
      shift
      cmd_contract_close "$@"
      ;;
    list)
      [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
      db_exec_opts "-header -column" "SELECT id, ts, substr(content, 1, 80) || '...' AS summary FROM context WHERE type='contract' ORDER BY ts DESC LIMIT 10;"
      ;;
    *)
      # Original behavior: create contract from JSON
      # Expected format: {"goal":"X","files":["a.sh"],"constraints":{"files":["a.sh","b.md"]},"tier":2}
      # constraints.files: exhaustive list of files the agent is allowed to touch.
      # Surgeons MUST verify git diff --name-only is a subset of constraints.files before commit.
      local content="$subcmd"
      [ -z "$content" ] && { echo "Usage: agentdb contract <json> | close [id|--stale] | list"; exit 1; }
      [ ! -f "$DB" ] && cmd_init >/dev/null

      local safe_content
      safe_content=$(sql_escape "$content")

      local id="CR-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
      db_exec "INSERT INTO context (id, type, agent, content, contract_id) VALUES ('$id', 'contract', 'orchestrator', '$safe_content', '$id');"
      echo "Contract: $id"
      ;;
  esac
}

cmd_contract_close() {
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }
  local target="${1:-}"

  if [ "$target" = "--stale" ]; then
    # Close contracts older than 24 hours
    local count
    count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract' AND ts < datetime('now', '-1 day');")
    db_exec "DELETE FROM context WHERE type='contract' AND ts < datetime('now', '-1 day');"
    echo "Closed $count stale contract(s)."
  elif [ -n "$target" ]; then
    # Close specific contract by ID (or partial match)
    local safe_target
    safe_target=$(sql_escape "$target")
    local count
    count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract' AND id LIKE '%${safe_target}%';")
    db_exec "DELETE FROM context WHERE type='contract' AND id LIKE '%${safe_target}%';"
    echo "Closed $count contract(s) matching '$target'."
  else
    # Close all contracts
    local count
    count=$(db_exec "SELECT COUNT(*) FROM context WHERE type='contract';")
    db_exec "DELETE FROM context WHERE type='contract';"
    echo "Closed all $count contract(s)."
  fi
}

cmd_verdict() {
  local result="${1:-}"
  local evidence="${2:-}"
  local contract_id="${3:-}"

  [ -z "$result" ] && { echo "Usage: agentdb verdict <pass|fail> <evidence> [contract_id]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  local safe_result safe_evidence safe_contract_id
  safe_result=$(sql_escape "$result")
  safe_evidence=$(sql_escape "$evidence")
  safe_contract_id=$(sql_escape "$contract_id")

  local id="VD-$(date +%Y%m%d%H%M%S)-$$-$RANDOM"
  local content
  if command -v jq >/dev/null 2>&1; then
    content=$(jq -n --arg r "$result" --arg e "$evidence" '{result:$r,evidence:$e}')
  else
    local json_result json_evidence
    json_result=$(json_escape "$result")
    json_evidence=$(json_escape "$evidence")
    content="{\"result\":\"$json_result\",\"evidence\":\"$json_evidence\"}"
  fi
  local safe_content
  safe_content=$(sql_escape "$content")
  db_exec "INSERT INTO context (id, type, agent, content, contract_id) VALUES ('$id', 'verdict', 'adversary', '$safe_content', '$safe_contract_id');"
  echo "Verdict: $result"
}

cmd_error() {
  local tool="${1:-}"
  local error="${2:-}"
  local file="${3:-}"
  local domain="${4:-}"

  [ -z "$tool" ] || [ -z "$error" ] && { echo "Usage: agentdb error <tool> <error> [file] [domain]"; exit 1; }
  [ ! -f "$DB" ] && cmd_init >/dev/null

  # H103: Auto-infer domain from file path or error content if not provided
  if [ -z "$domain" ]; then
    case "$file$error" in
      *hook*|*guard*|*plugin*)  domain="infrastructure" ;;
      *test*|*spec*|*assert*)  domain="testing" ;;
      *auth*|*secret*|*token*) domain="security" ;;
      *merge*|*conflict*|*worktree*|*agent*) domain="coordination" ;;
      *api*|*endpoint*|*route*) domain="backend" ;;
      *) domain="" ;;
    esac
  fi

  local safe_tool safe_error safe_file safe_domain
  safe_tool=$(sql_escape "$tool")
  safe_error=$(sql_escape "$error")
  safe_file=$(sql_escape "$file")
  safe_domain=$(sql_escape "$domain")

  # Write ts explicitly: legacy DBs created the errors table with a
  # CURRENT_TIMESTAMP default (space-separated, no Z), which breaks ISO-8601
  # sorts. strftime here keeps new rows consistent regardless of column default.
  db_exec "INSERT INTO errors (tool, error, file, domain, ts) VALUES ('$safe_tool', '$safe_error', '$safe_file', '$safe_domain', strftime('%Y-%m-%dT%H:%M:%fZ','now'));"
}

cmd_query() {
  local sql="${1:-}"
  [ -z "$sql" ] && { echo "Usage: agentdb query <sql>"; exit 1; }
  [ ! -f "$DB" ] && { echo "No DB"; exit 1; }

  db_exec_opts "-header -column" "$sql"
}

cmd_stats() {
