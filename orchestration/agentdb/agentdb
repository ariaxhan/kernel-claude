  fi
  echo ""

  # === Compaction ===
  echo "## Compaction (last ${days}d)"
  local has_compaction
  has_compaction=$(db_exec "SELECT 1 FROM sqlite_master WHERE type='table' AND name='compaction_events' LIMIT 1;" 2>/dev/null || echo "")
