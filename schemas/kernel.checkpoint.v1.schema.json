{
  "$id": "kernel.checkpoint/v1",
  "title": "KERNEL checkpoint manifest",
  "description": "Bounded mid-task progress record. Smaller than a handoff: enough to resume after a context reset, not a full session transfer. Produced by /kernel:checkpoint; consumed by /kernel:ingest. A checkpoint never overrides live repository state (authority order: live state > user instruction > manifest).",
  "type": "object",
  "required": ["schema", "identity", "provenance", "task", "steps_completed", "pending_steps", "resume"],
  "properties": {
    "schema": { "type": "string", "enum": ["kernel.checkpoint/v1"] },

    "identity": {
      "type": "object",
      "required": ["name", "created"],
      "properties": {
        "name": { "type": "string" },
        "created": { "type": "string", "description": "ISO 8601 timestamp" },
        "session": { "type": "string" }
      }
    },

    "provenance": {
      "type": "object",
      "required": ["branch", "commit", "dirty"],
      "properties": {
        "branch": { "type": "string" },
        "commit": { "type": "string" },
        "dirty": { "type": "boolean" },
        "dirty_tree_sha256": { "type": "string", "description": "sha256 of `git diff --binary HEAD` when dirty is true" }
      }
    },

    "task": {
      "type": "object",
      "required": ["goal"],
      "properties": {
        "goal": { "type": "string" },
        "handoff_ref": { "type": "string", "description": "parent kernel.handoff/v1 file, if this checkpoint refines one" },
        "contract_ref": { "type": "string", "description": "governing _meta/contracts/ file" }
      }
    },

    "steps_completed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "evidence"],
        "properties": {
          "step": { "type": "string" },
          "evidence": { "type": "string", "description": "verification evidence, not intent — a command output, commit sha, passing test" }
        }
      }
    },

    "current_outputs": {
      "type": "array",
      "description": "files produced so far",
      "items": { "type": "string" }
    },

    "pending_steps": { "type": "array", "items": { "type": "string" } },

    "resume": {
      "type": "object",
      "required": ["position", "next_operation"],
      "properties": {
        "position": { "type": "string", "description": "exact place in the work, e.g. 'commit 3 of 5: state skills rewritten, tests not yet retargeted'" },
        "entrypoint": { "type": "string", "description": "skill or phase to re-enter" },
        "next_operation": { "type": "string", "description": "the literal first action to take on resume" }
      }
    },

    "context": {
      "type": "object",
      "description": "optional bounded context spec, same policy semantics as kernel.handoff/v1",
      "properties": {
        "policy": {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": { "type": "string", "enum": ["sealed", "bounded", "advisory"] }
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "lines": { "type": "string" },
              "heading": { "type": "string" },
              "grep": { "type": "string" },
              "context": { "type": "integer" },
              "git_diff": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "forbidden": { "type": "array", "items": { "type": "string" } },
        "budget": {
          "type": "object",
          "properties": {
            "target_tokens": { "type": "integer", "minimum": 1 },
            "max_tokens": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
