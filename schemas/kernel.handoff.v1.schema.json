{
  "$id": "kernel.handoff/v1",
  "title": "KERNEL handoff manifest",
  "description": "Authoritative resumable session manifest. The JSON file is canonical; any YAML or markdown rendering is non-authoritative. Consumed by /kernel:ingest; produced by /kernel:handoff. Validated by orchestration/manifest/kernel-manifest (subset validator: type, required, properties, enum, items, additionalProperties; duplicate keys rejected at parse).",
  "type": "object",
  "required": [
    "schema",
    "identity",
    "provenance",
    "objective",
    "workflow",
    "context",
    "execution",
    "resume"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "kernel.handoff/v1"
      ],
      "x-kernel-enforced-by": "agent"
    },
    "identity": {
      "type": "object",
      "required": [
        "name",
        "created"
      ],
      "properties": {
        "name": {
          "type": "string",
          "x-kernel-enforced-by": "agent"
        },
        "created": {
          "type": "string",
          "description": "ISO 8601 timestamp",
          "x-kernel-enforced-by": "agent"
        },
        "session": {
          "type": "string",
          "description": "originating session id",
          "x-kernel-enforced-by": "agent"
        },
        "tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "x-kernel-enforced-by": "agent"
        }
      },
      "x-kernel-enforced-by": "agent"
    },
    "provenance": {
      "type": "object",
      "required": [
        "branch",
        "commit",
        "dirty"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "x-kernel-enforced-by": "divergence"
        },
        "commit": {
          "type": "string",
          "description": "full sha of HEAD at handoff time",
          "x-kernel-enforced-by": "divergence"
        },
        "dirty": {
          "type": "boolean",
          "x-kernel-enforced-by": "divergence"
        },
        "artifacts": {
          "type": "array",
          "description": "files this handoff pins; hash mismatch at resume = divergence",
          "items": {
            "type": "object",
            "required": [
              "path",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string",
                "x-kernel-enforced-by": "divergence"
              },
              "sha256": {
                "type": "string",
                "x-kernel-enforced-by": "divergence"
              },
              "purpose": {
                "type": "string",
                "x-kernel-enforced-by": "divergence"
              }
            }
          },
          "x-kernel-enforced-by": "divergence"
        },
        "retrospective_refs": {
          "type": "array",
          "description": "kernel.retrospective-result/v1 files whose mutations this work depends on",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "divergence"
        }
      },
      "x-kernel-enforced-by": "divergence"
    },
    "objective": {
      "type": "object",
      "required": [
        "goal",
        "success_conditions"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "x-kernel-enforced-by": "agent"
        },
        "success_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "agent"
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "agent"
        }
      },
      "x-kernel-enforced-by": "agent"
    },
    "contract": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "string",
          "description": "path to the governing _meta/contracts/ file",
          "x-kernel-enforced-by": "agent"
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "agent"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "agent"
        },
        "decisions_accepted": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "decision"
            ],
            "properties": {
              "decision": {
                "type": "string",
                "x-kernel-enforced-by": "agent"
              },
              "rationale": {
                "type": "string",
                "x-kernel-enforced-by": "agent"
              }
            }
          },
          "x-kernel-enforced-by": "agent"
        },
        "alternatives_rejected": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "alternative"
            ],
            "properties": {
              "alternative": {
                "type": "string",
                "x-kernel-enforced-by": "agent"
              },
              "reason": {
                "type": "string",
                "x-kernel-enforced-by": "agent"
              }
            }
          },
          "x-kernel-enforced-by": "agent"
        }
      },
      "x-kernel-enforced-by": "agent"
    },
    "workflow": {
      "type": "object",
      "required": [
        "phases"
      ],
      "properties": {
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "status"
            ],
            "properties": {
              "name": {
                "type": "string",
                "x-kernel-enforced-by": "divergence"
              },
              "status": {
                "type": "string",
                "enum": [
                  "inherited",
                  "required",
                  "invalidated"
                ],
                "x-kernel-enforced-by": "divergence"
              },
              "evidence": {
                "type": "string",
                "description": "why an inherited phase may be trusted",
                "x-kernel-enforced-by": "divergence"
              }
            }
          },
          "x-kernel-enforced-by": "divergence"
        },
        "invalidation_rules": {
          "type": "array",
          "description": "live-state triggers that flip inherited phases to required",
          "items": {
            "type": "object",
            "required": [
              "when",
              "invalidates"
            ],
            "properties": {
              "when": {
                "type": "object",
                "required": [
                  "event"
                ],
                "properties": {
                  "event": {
                    "type": "string",
                    "x-kernel-enforced-by": "divergence"
                  },
                  "path_glob": {
                    "type": "string",
                    "x-kernel-enforced-by": "divergence"
                  }
                },
                "x-kernel-enforced-by": "divergence"
              },
              "invalidates": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "x-kernel-enforced-by": "divergence"
              }
            }
          },
          "x-kernel-enforced-by": "divergence"
        }
      },
      "x-kernel-enforced-by": "divergence"
    },
    "runtime": {
      "type": "object",
      "properties": {
        "required_skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "x-kernel-enforced-by": "compiler"
              },
              "version": {
                "type": "integer",
                "description": "kernel.version of the skill when pinned",
                "x-kernel-enforced-by": "compiler"
              },
              "sha256": {
                "type": "string",
                "description": "hash of SKILL.md when practical",
                "x-kernel-enforced-by": "compiler"
              }
            }
          },
          "x-kernel-enforced-by": "compiler"
        },
        "optional_skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "compiler"
        },
        "preflight": {
          "type": "array",
          "description": "checks ingest runs before resuming; failure = stop and report",
          "items": {
            "type": "object",
            "required": [
              "check"
            ],
            "properties": {
              "check": {
                "type": "string",
                "enum": [
                  "current_branch",
                  "path_exists",
                  "argv"
                ],
                "x-kernel-enforced-by": "compiler"
              },
              "expected": {
                "type": "string",
                "x-kernel-enforced-by": "compiler"
              },
              "path": {
                "type": "string",
                "x-kernel-enforced-by": "compiler"
              },
              "argv": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "x-kernel-enforced-by": "compiler"
              }
            }
          },
          "x-kernel-enforced-by": "compiler"
        }
      },
      "x-kernel-enforced-by": "compiler"
    },
    "context": {
      "type": "object",
      "required": [
        "policy"
      ],
      "properties": {
        "policy": {
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "sealed",
                "bounded",
                "advisory"
              ],
              "x-kernel-enforced-by": "hook"
            }
          },
          "x-kernel-enforced-by": "hook"
        },
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "description": "context selector v1. Must contain 'path' or 'git_diff'; refinement keys (lines|heading|grep) apply to 'path'. Enforced in validator code, not schema (subset validator has no oneOf). Deferred: yaml_path, json_path, symbol.",
            "properties": {
              "path": {
                "type": "string",
                "x-kernel-enforced-by": "compiler"
              },
              "lines": {
                "type": "string",
                "description": "'A-B' inclusive line range",
                "x-kernel-enforced-by": "compiler"
              },
              "heading": {
                "type": "string",
                "description": "markdown heading text; loads that section",
                "x-kernel-enforced-by": "compiler"
              },
              "grep": {
                "type": "string",
                "description": "pattern; loads matches with context",
                "x-kernel-enforced-by": "compiler"
              },
              "context": {
                "type": "integer",
                "description": "surrounding lines for grep (default 3)",
                "x-kernel-enforced-by": "compiler"
              },
              "git_diff": {
                "type": "string",
                "description": "'revA..revB'; loads the diff instead of a file",
                "x-kernel-enforced-by": "compiler"
              },
              "reason": {
                "type": "string",
                "x-kernel-enforced-by": "compiler"
              }
            }
          },
          "x-kernel-enforced-by": "compiler"
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "object",
            "description": "context selector v1. Must contain 'path' or 'git_diff'; refinement keys (lines|heading|grep) apply to 'path'. Enforced in validator code, not schema (subset validator has no oneOf). Deferred: yaml_path, json_path, symbol.",
            "properties": {
              "path": {
                "type": "string",
                "x-kernel-enforced-by": "compiler"
              },
              "lines": {
                "type": "string",
                "description": "'A-B' inclusive line range",
                "x-kernel-enforced-by": "compiler"
              },
              "heading": {
                "type": "string",
                "description": "markdown heading text; loads that section",
                "x-kernel-enforced-by": "compiler"
              },
              "grep": {
                "type": "string",
                "description": "pattern; loads matches with context",
                "x-kernel-enforced-by": "compiler"
              },
              "context": {
                "type": "integer",
                "description": "surrounding lines for grep (default 3)",
                "x-kernel-enforced-by": "compiler"
              },
              "git_diff": {
                "type": "string",
                "description": "'revA..revB'; loads the diff instead of a file",
                "x-kernel-enforced-by": "compiler"
              },
              "reason": {
                "type": "string",
                "x-kernel-enforced-by": "compiler"
              }
            }
          },
          "x-kernel-enforced-by": "compiler"
        },
        "forbidden": {
          "type": "array",
          "description": "glob patterns; sealed mode blocks access via guard-context hook",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "hook"
        },
        "budget": {
          "type": "object",
          "properties": {
            "target_tokens": {
              "type": "integer",
              "minimum": 1,
              "x-kernel-enforced-by": "compiler"
            },
            "max_tokens": {
              "type": "integer",
              "minimum": 1,
              "x-kernel-enforced-by": "compiler"
            }
          },
          "x-kernel-enforced-by": "compiler"
        }
      },
      "x-kernel-enforced-by": "compiler"
    },
    "execution": {
      "type": "object",
      "required": [
        "entry_phase"
      ],
      "properties": {
        "entry_phase": {
          "type": "string",
          "x-kernel-enforced-by": "agent"
        },
        "entrypoint": {
          "type": "string",
          "description": "the exact first operation to perform",
          "x-kernel-enforced-by": "agent"
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "agent"
        },
        "checkpoints": {
          "type": "array",
          "description": "points at which a kernel.checkpoint/v1 should be emitted",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "agent"
        }
      },
      "x-kernel-enforced-by": "agent"
    },
    "open_threads": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "x-kernel-enforced-by": "agent"
    },
    "warnings": {
      "type": "array",
      "description": "failed approaches; do not re-explore",
      "items": {
        "type": "string"
      },
      "x-kernel-enforced-by": "agent"
    },
    "outputs": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kernel-enforced-by": "agent"
        },
        "completion": {
          "type": "string",
          "description": "the operation that closes this manifest (e.g. 'kernel-manifest deactivate + agentdb write-end')",
          "x-kernel-enforced-by": "agent"
        }
      },
      "x-kernel-enforced-by": "agent"
    },
    "resume": {
      "type": "object",
      "required": [
        "prompt"
      ],
      "properties": {
        "prompt": {
          "type": "string",
          "description": "one-line continuation prompt for the next session",
          "x-kernel-enforced-by": "agent"
        }
      },
      "x-kernel-enforced-by": "agent"
    }
  }
}
