{
  "$id": "kernel.context-receipt/v1",
  "title": "KERNEL context receipt",
  "description": "Emitted by `kernel-manifest compile` when ingest assembles a bounded runtime from a manifest. Token counts are chars/4 ESTIMATES (estimation_method documents this); treat as directional, not exact. Grounding: EXP-L21 measured load-bearing context flat at ~47-71k/decision while attended context grew 7-11x \u2014 the receipt is how a resume proves it stayed near the flat line.",
  "type": "object",
  "required": [
    "schema",
    "manifest",
    "manifest_sha256",
    "bundle_sha256",
    "total_estimated_tokens",
    "status",
    "estimation_method"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "kernel.context-receipt/v1"
      ],
      "x-kernel-enforced-by": "compiler"
    },
    "manifest": {
      "type": "string",
      "description": "path of the manifest this receipt was compiled from",
      "x-kernel-enforced-by": "compiler"
    },
    "manifest_sha256": {
      "type": "string",
      "x-kernel-enforced-by": "compiler"
    },
    "bundle_sha256": {
      "type": "string",
      "x-kernel-enforced-by": "compiler"
    },
    "created": {
      "type": "string",
      "x-kernel-enforced-by": "compiler"
    },
    "manifest_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "project_instructions_tokens": {
      "type": "integer",
      "description": "CLAUDE.md chain + session-start hook block (boot layer)",
      "x-kernel-enforced-by": "compiler"
    },
    "always_skills_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "workflow_skills_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "domain_skills_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "selected_artifacts_tokens": {
      "type": "integer",
      "description": "sum over resolved context selectors",
      "x-kernel-enforced-by": "compiler"
    },
    "agentdb_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "total_estimated_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "target_budget_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "maximum_budget_tokens": {
      "type": "integer",
      "x-kernel-enforced-by": "compiler"
    },
    "status": {
      "type": "string",
      "enum": [
        "within_budget",
        "target_exceeded",
        "maximum_exceeded"
      ],
      "x-kernel-enforced-by": "compiler"
    },
    "estimation_method": {
      "type": "string",
      "description": "e.g. 'chars/4 (directional; structural overhead undercounted)'",
      "x-kernel-enforced-by": "compiler"
    },
    "selections": {
      "type": "array",
      "description": "per-selector resolution results",
      "items": {
        "type": "object",
        "required": [
          "selector",
          "resolved",
          "outcome",
          "estimated_tokens"
        ],
        "properties": {
          "selector": {
            "type": "string",
            "description": "human-readable selector summary",
            "x-kernel-enforced-by": "compiler"
          },
          "resolved": {
            "type": "boolean",
            "x-kernel-enforced-by": "compiler"
          },
          "outcome": {
            "type": "string",
            "enum": [
              "resolved",
              "empty",
              "invalid",
              "missing"
            ],
            "x-kernel-enforced-by": "compiler"
          },
          "resolved_sha256": {
            "type": "string",
            "x-kernel-enforced-by": "compiler"
          },
          "estimated_tokens": {
            "type": "integer",
            "x-kernel-enforced-by": "compiler"
          },
          "note": {
            "type": "string",
            "description": "e.g. 'file missing', 'heading not found'",
            "x-kernel-enforced-by": "compiler"
          }
        }
      },
      "x-kernel-enforced-by": "compiler"
    },
    "loads_beyond_manifest": {
      "type": "array",
      "description": "bounded-mode ledger: context loaded beyond the manifest, each with an explicit reason. Populated from _meta/.context-ledger at deactivate time. Sealed mode: must stay empty.",
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "x-kernel-enforced-by": "compiler"
          },
          "reason": {
            "type": "string",
            "x-kernel-enforced-by": "compiler"
          },
          "estimated_tokens": {
            "type": "integer",
            "x-kernel-enforced-by": "compiler"
          }
        }
      },
      "x-kernel-enforced-by": "compiler"
    }
  }
}
